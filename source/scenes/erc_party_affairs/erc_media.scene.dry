            Q.jxcat_parlament_girona_[d+"_support"] += 1*(Q.jxcat_relations/100);
            Q.jxcat_parlament_lleida_[d+"_support"] += 1*(Q.jxcat_relations/100);
            Q.jxcat_parlament_tarragona_[d+"_support"] += 1*(Q.jxcat_relations/100);
