    Q.erc_parlament_girona_rural_support += 6*(1-Q.erc_dissent/100) + Q.teresa_jorda_advisor;
    Q.erc_parlament_lleida_rural_support += 6*(1-Q.erc_dissent/100) + Q.teresa_jorda_advisor;
