switch (Q.random_seed) {
  default:
    Q.random_seed_quote_text = "I like Catalan people because they do \"stuff\".";
    Q.random_seed_author = "Mariano Rajoy, Presidente del Gobierno, 2017";
  case 0:
    Q.random_seed_quote_text = "We deserve to be stompped by all the sons of Aznar and Don Pelayo if we don't manage to agree with eachother.";
    Q.random_seed_author = "Gabriel Rufian, ERC MP at the Congreso, 2019";
    break;
  case 1:
    Q.random_seed_quote_text = "We were going slow, because we were going far.";
    Q.random_seed_author = "CUP's post-election negotiation motto, circa 2015";
    break;
  case 2:
    Q.random_seed_quote_text = "Everything is ready for the desconnection* \[independence\]. *All that will be needed is to press a button."
    Q.random_seed_author = "Carles Viver Pi-Sunyer, Parlament's Comissioner for the National Transition, 2015";
    break;
  case 3:
    Q.random_seed_quote_text = "I am not asking for a single euro, just for an agreement.";
    Q.random_seed_author = "Artur Mas, President de la Generalitat, 2012";
    break;
  case 4:
    Q.random_seed_quote_text = "\"What cannot be, cannot be, on top of that it is impossible.\"";
    Q.random_seed_author = "Mariano Rajoy, Presidente del Gobierno, 2017";
    break;
}
!}
