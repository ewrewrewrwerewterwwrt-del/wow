@cup_no_join
title: jxsi is no place for us
on-arrival: {!
    Q.cup_endavant_strength += 1;
    Q.cup_endavant_dissent -= 5;
    Q.cup_poblelliure_dissent += 2;
    Q.cup_thirdsector_strength += 5;
    Q.cup_thirdsector_dissent -= 2;

    const _activeCiu = Q.cdc_parlament_s > 0 ? "cdc" : Q.dl_parlament_s > 0 ? "dl" : "pdcat"

    if (Q.jxsi_formation_num == 40) {
        Q.jxsi_leader = Q[_activeCiu + "_leader"];
        Q.jxsi_leader_gender = Q[_activeCiu + "_leader_gender"];
    } else {
        Q.jxsi_leader = "Raül Romeva"
        Q.jxsi_leader_gender = "m";
    }

    Q.jxsi_parlament_s = Q[_activeCiu + "_parlament_s"] + Q.erc_parlament_s;
    Q.erc_parlament_s = 0;
    Q[_activeCiu + "_parlament_s"] = 0;

    for (const c of Q.parlament_constituencies) {
        Q["abstain_parlament_" + c + "_buss_support"] -= 1;
        Q["abstain_parlament_" + c + "_ind_support"] -= 1;
        Q["abstain_parlament_" + c + "_middle_support"] -= 2;
        Q["abstain_parlament_" + c + "_unemployed_support"] -= 1;
        Q["abstain_parlament_" + c + "_young_support"] -= 2;
        Q["abstain_parlament_" + c + "_retired_support"] -= 2;
        Q["abstain_parlament_" + c + "_rural_support"] -= 2.5;
        Q["jxsi_parlament_" + c + "_buss_support"] =  Q[_activeCiu + "_parlament_" + c + "_buss_support"] + Q["erc_parlament_" + c + "_buss_support"] + 0.5;
        Q["jxsi_parlament_" + c + "_ind_support"] += Q[_activeCiu + "_parlament_" + c + "_ind_support"] + Q["erc_parlament_" + c + "_ind_support"] - 1;
        Q["jxsi_parlament_" + c + "_middle_support"] += Q[_activeCiu + "_parlament_" + c + "_middle_support"] + Q["erc_parlament_" + c + "_middle_support"] - 1;
        Q["jxsi_parlament_" + c + "_unemployed_support"] += Q[_activeCiu + "_parlament_" + c + "_unemployed_support"] + Q["erc_parlament_" + c + "_unemployed_support"] - 3;
        Q["jxsi_parlament_" + c + "_young_support"] += Q[_activeCiu + "_parlament_" + c + "_young_support"] + Q["erc_parlament_" + c + "_young_support"] - 2;
        Q["jxsi_parlament_" + c + "_retired_support"] += Q[_activeCiu + "_parlament_" + c + "_retired_support"] + Q["erc_parlament_" + c + "_retired_support"] + 1.5;
        Q["jxsi_parlament_" + c + "_rural_support"] += Q[_activeCiu + "_parlament_" + c + "_rural_support"] + Q["erc_parlament_" + c + "_rural_support"] + 0.75;
        if (Q.jxsi_formation_num == 40) {
            // Anti-ciu, indy vote goes to CUP
            Q["cup_parlament_" + c + "_buss_support"] += 0.5;
            Q["cup_parlament_" + c + "_ind_support"] += 2;
            Q["cup_parlament_" + c + "_middle_support"] += 3;
            Q["cup_parlament_" + c + "_unemployed_support"] += 4;
            Q["cup_parlament_" + c + "_young_support"] += 4;
            Q["cup_parlament_" + c + "_retired_support"] += 0.5;
            Q["cup_parlament_" + c + "_rural_support"] += 1.75;
        } else {
            Q["jxsi_parlament_" + c + "_buss_support"] += 0.5;
            Q["jxsi_parlament_" + c + "_ind_support"] += 2;
            Q["jxsi_parlament_" + c + "_middle_support"] += 3;
            Q["jxsi_parlament_" + c + "_unemployed_support"] += 4;
            Q["jxsi_parlament_" + c + "_young_support"] += 4;
            Q["jxsi_parlament_" + c + "_retired_support"] += 0.5;
            Q["jxsi_parlament_" + c + "_rural_support"] += 1.75;
        }
        Q["erc_parlament_" + c + "_buss_support"] = 0;
        Q["erc_parlament_" + c + "_ind_support"] = 0;
        Q["erc_parlament_" + c + "_middle_support"] = 0;
        Q["erc_parlament_" + c + "_unemployed_support"] = 0;
        Q["erc_parlament_" + c + "_young_support"] = 0;
        Q["erc_parlament_" + c + "_retired_support"] = 0;
        Q["erc_parlament_" + c + "_rural_support"] = 0;
        Q[_activeCiu + "_parlament_" + c + "_buss_support"] = 0;
        Q[_activeCiu + "_parlament_" + c + "_ind_support"] = 0;
        Q[_activeCiu + "_parlament_" + c + "_middle_support"] = 0;
        Q[_activeCiu + "_parlament_" + c + "_unemployed_support"] = 0;
        Q[_activeCiu + "_parlament_" + c + "_young_support"] = 0;
        Q[_activeCiu + "_parlament_" + c + "_retired_support"] = 0;
        Q[_activeCiu + "_parlament_" + c + "_rural_support"] = 0;
    }
    
    Q.independence_movement += 5;
    Q.independence_trust += 15;
!}

For one reason or another, the CUP will go to the next Parlament election outside the jxsi umbrella. 

- @post_event: Let's hope this is for the best

@cup_join_mas
title: Let's join in [? if cdc_parlament_s > 0: [+ cdc_leader +]?][? if dl_parlament_s > 0: [+ dl_leader +]?][? if pdcat_parlament_s > 0: [+ pdcat_leader +]?]'s jxsi
subtitle: This will not please everyone in the party
choose-if: cup_poblelliure_strength > cup_endavant_strength + 5 and cup_poblelliure_dissent <= 15 and cup_thirdsector_dissent <= 15 and erc_relations >= 55 and ((cdc_relations >= 55 and cdc_parlament_s > 0) or (dl_relations >= 55 and dl_parlament_s > 0) or (pdcat_relations >= 55 and pdcat_parlament_s > 0))
unavailable-subtitle: [? if cup_poblelliure_strength <= cup_endavant_strength + 5: Poble Lliure is not strong enough as a party faction to push for this. ?][? if erc_relations < 55: We don't have good enough relations with ERC. ?][? if ((cdc_relations < 55 and cdc_parlament_s > 0) or (dl_relations < 55 and dl_parlament_s > 0) or (pdcat_relations < 55 and pdcat_parlament_s > 0)): We don't have good enough relations with [? if cdc_parlament_s > 0: CDC?][? if dl_parlament_s > 0: DL?][? if pdcat_parlament_s > 0: the PDeCAT?]. ?]
on-arrival: {!
    if (!Q.achievement_jxsi_de_debo) {
        window.achievementNotif('Junts (de debò) pel Sí', 'img/achievements/jxsi_dedebo.jpg', 4);
    }
    this.achieve("jxsi_de_debo");
    
    Q.cup_in_jxsi = true;
    Q.player_in_jxsi = true;
    const _activeCiu = Q.cdc_parlament_s > 0 ? "cdc" : Q.dl_parlament_s > 0 ? "dl" : "pdcat";
    const _activeComuns = Q.icv_parlament_s > 0 ? "icv" : Q.csqp_parlament_s > 0 ? "csqp" : Q.cecp_parlament_s > 0 ? "cecp" : "ecp";

    Q.jxsi_leader = Q[_activeCiu + "_leader"];
    Q.jxsi_leader_gender = Q[_activeCiu + "_leader_gender"];

    Q.jxsi_parlament_s = Q[_activeCiu + "_parlament_s"] + Q.erc_parlament_s + Q.cup_parlament_s;
    Q.erc_parlament_s = 0;
    Q[_activeCiu + "_parlament_s"] = 0;
    Q.cup_parlament_s = 0;

    for (const c of Q.parlament_constituencies) {
        Q["abstain_parlament_" + c + "_buss_support"] -= 1;
        Q["abstain_parlament_" + c + "_ind_support"] -= 1;
        Q["abstain_parlament_" + c + "_middle_support"] -= 2;
        Q["abstain_parlament_" + c + "_unemployed_support"] -= 1;
        Q["abstain_parlament_" + c + "_young_support"] -= 2;
        Q["abstain_parlament_" + c + "_retired_support"] -= 2;
        Q["abstain_parlament_" + c + "_rural_support"] -= 2;
        Q["jxsi_parlament_" + c + "_buss_support"] =  Q[_activeCiu + "_parlament_" + c + "_buss_support"] + Q["erc_parlament_" + c + "_buss_support"] + Q["cup_parlament_" + c + "_buss_support"];
        Q["jxsi_parlament_" + c + "_ind_support"] += Q[_activeCiu + "_parlament_" + c + "_ind_support"] + Q["erc_parlament_" + c + "_ind_support"] + Q["cup_parlament_" + c + "_ind_support"] - 1;
        Q["jxsi_parlament_" + c + "_middle_support"] += Q[_activeCiu + "_parlament_" + c + "_middle_support"] + Q["erc_parlament_" + c + "_middle_support"] + Q["cup_parlament_" + c + "_middle_support"];
        Q["jxsi_parlament_" + c + "_unemployed_support"] += Q[_activeCiu + "_parlament_" + c + "_unemployed_support"] + Q["erc_parlament_" + c + "_unemployed_support"] + Q["cup_parlament_" + c + "_unemployed_support"] - 2;
        Q["jxsi_parlament_" + c + "_young_support"] += Q[_activeCiu + "_parlament_" + c + "_young_support"] + Q["erc_parlament_" + c + "_young_support"] + Q["cup_parlament_" + c + "_young_support"] - 1;
        Q["jxsi_parlament_" + c + "_retired_support"] += Q[_activeCiu + "_parlament_" + c + "_retired_support"] + Q["erc_parlament_" + c + "_retired_support"] + Q["cup_parlament_" + c + "_retired_support"];
        Q["jxsi_parlament_" + c + "_rural_support"] += Q[_activeCiu + "_parlament_" + c + "_rural_support"] + Q["erc_parlament_" + c + "_rural_support"] + Q["cup_parlament_" + c + "_rural_support"] + 1;

        // Anti-ciu vote goes to Comuns
        Q[_activeComuns + "_parlament_" + c + "_buss_support"] += 0.5;
        Q[_activeComuns + "_parlament_" + c + "_ind_support"] += 2;
        Q[_activeComuns + "_parlament_" + c + "_middle_support"] += 2;
        Q[_activeComuns + "_parlament_" + c + "_unemployed_support"] += 2;
        Q[_activeComuns + "_parlament_" + c + "_young_support"] += 2;
        Q[_activeComuns + "_parlament_" + c + "_retired_support"] += 1;
        Q[_activeComuns + "_parlament_" + c + "_rural_support"] += 0.75;

        Q["erc_parlament_" + c + "_buss_support"] = 0;
        Q["erc_parlament_" + c + "_ind_support"] = 0;
        Q["erc_parlament_" + c + "_middle_support"] = 0;
        Q["erc_parlament_" + c + "_unemployed_support"] = 0;
        Q["erc_parlament_" + c + "_young_support"] = 0;
        Q["erc_parlament_" + c + "_retired_support"] = 0;
        Q["erc_parlament_" + c + "_rural_support"] = 0;
        Q["cup_parlament_" + c + "_buss_support"] = 0;
        Q["cup_parlament_" + c + "_ind_support"] = 0;
        Q["cup_parlament_" + c + "_middle_support"] = 0;
        Q["cup_parlament_" + c + "_unemployed_support"] = 0;
        Q["cup_parlament_" + c + "_young_support"] = 0;
        Q["cup_parlament_" + c + "_retired_support"] = 0;
        Q["cup_parlament_" + c + "_rural_support"] = 0;
        Q[_activeCiu + "_parlament_" + c + "_buss_support"] = 0;
        Q[_activeCiu + "_parlament_" + c + "_ind_support"] = 0;
        Q[_activeCiu + "_parlament_" + c + "_middle_support"] = 0;
        Q[_activeCiu + "_parlament_" + c + "_unemployed_support"] = 0;
        Q[_activeCiu + "_parlament_" + c + "_young_support"] = 0;
        Q[_activeCiu + "_parlament_" + c + "_retired_support"] = 0;
        Q[_activeCiu + "_parlament_" + c + "_rural_support"] = 0;
    }
    
    Q.independence_movement += 8;
    Q.independence_trust += 20;

    Q.cup_endavant_dissent += 25;
    Q.cup_poblelliure_strength += 10;
    Q.cup_poblelliure_dissent -= 5;
    Q.cup_thirdsector_dissent += 5;
!}

This is highly unexpected and has angered many on the left of the party, specially those in Endavant already skeptical of institutional participation. Be it as it may, a decision has now been taken.

- @post_event: Let's hope this is for the best

