@devolution_dump
title: Maybe we don't need to push for more devolution
view-if: congreso_coalition_negotiated_renfe or congreso_coalition_negotiated_ports or congreso_coalition_negotiated_education or congreso_coalition_negotiated_police or congreso_coalition_negotiated_borders
choose-if: congreso_coalition_negotiated_renfe or congreso_coalition_negotiated_ports or congreso_coalition_negotiated_education or congreso_coalition_negotiated_police or congreso_coalition_negotiated_borders
on-arrival: {!
    if (Q.congreso_coalition_negotiated_renfe) Q.congreso_coalition_leverage += 1;
    if (Q.congreso_coalition_negotiated_ports) Q.congreso_coalition_leverage += 1;
    if (Q.congreso_coalition_negotiated_education) Q.congreso_coalition_leverage += 1;
    if (Q.congreso_coalition_negotiated_police) Q.congreso_coalition_leverage += 1;
    if (Q.congreso_coalition_negotiated_borders) Q.congreso_coalition_leverage += 1;
    Q.congreso_coalition_negotiated_renfe = 0;
    Q.congreso_coalition_negotiated_ports = 0;
    Q.congreso_coalition_negotiated_education = 0;
    Q.congreso_coalition_negotiated_police = 0;
    Q.congreso_coalition_negotiated_borders = 0;
!}
go-to: choices

@const_reform
title: It's time to reform the Constitution!
subtitle: This is already in the agenda of [+ congreso_left_carrier +], yet we could push for further decentralization and even a referendum on the monarchy.
choose-if: congreso_left_carrier == congreso_coalition_lead_party and congreso_coalition_leverage > 0 and not congreso_coalition_negotiated_reform
unavailable-subtitle: [? if congreso_left_carrier != congreso_coalition_lead_party: The [+ congreso_coalition_lead_party +] has no intention of opening this can of worms. ?][? if congreso_coalition_negotiated_reform: This is already in our demands list. ?][? if congreso_coalition_leverage < 1 and not congreso_coalition_negotiated_reform: We lack leverage to demand this, on top of the rest we've already asked for. ?]
on-arrival: congreso_coalition_negotiated_reform = 1; congreso_coalition_leverage -= 1;
go-to: choices

