subtitle: The Mossos d'Esquadra should be the only police force in Catalonia.
view-if: not competence_police
choose-if: (congreso_left_carrier == congreso_coalition_lead_party or congreso_coalition_lead_party == "psoe") and congreso_coalition_leverage > 0 and not congreso_coalition_negotiated_police
unavailable-subtitle: [? if congreso_left_carrier != congreso_coalition_lead_party and congreso_coalition_lead_party != "psoe": The [+ congreso_coalition_lead_party +] has already ruled this out. ?][? if congreso_coalition_negotiated_police: This is already in our demands list. ?][? if congreso_coalition_leverage < 1 and not congreso_coalition_negotiated_police: We lack leverage to demand this, on top of the rest we've already asked for. ?]
on-arrival: congreso_coalition_negotiated_police = 1; congreso_coalition_leverage -= 1;
