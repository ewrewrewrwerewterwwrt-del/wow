title: Congreso Elections - [+ next_spanish_election_month : month +] [+ next_spanish_election_year +]
tags: election
view-if: year = next_spanish_election_year and month = next_spanish_election_month and (week = next_spanish_election_week or not rubicon)
new-page: true
set-bg: img/congreso.jpg
on-arrival: {!
var congreso_size = 0;
for (var constituency of Q.congreso_constituencies) {
    congreso_size += Q.congreso_seats[constituency];
}
Q.congreso_s_majority = Math.floor(congreso_size/2) + 1;
!}
go-to: election_algorithm.esp_congreso
set-jump: congreso_election.post_election

@post_election
new-page: true
on-arrival: {!
    Q.next_spanish_election_year += 4;
    if (Q.rubicon) {
        Q.next_spanish_election_time += 48 * 4;
    } else {
        Q.next_spanish_election_time += 48;
    }
    
    if (Q.player_party == "cup" && Q.cup_parlament_s > 0) {
        Q.position_disp = "<span style='font-style: italic'>Opposition</span>";
    } else {
        Q.game_over_trigger = true;
    }
!}
on-display: {!
