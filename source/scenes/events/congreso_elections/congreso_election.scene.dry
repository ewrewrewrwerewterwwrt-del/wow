    if (window && d3) {
        var width = 500;
        var height = 500;
        var screenWidth =  document.getElementById('content').offsetWidth;
        if (screenWidth < width - 50) {
            width = screenWidth - 50;
            height = width;
            document.getElementById("congreso").style.height = screenWidth/2 + "px";
        }
        var parliament = d3.parliament();
        parliament.width(width).height(height).innerRadiusCoef(0.4);
        parliament.enter.fromCenter(true).smallToBig(true);
        parliament.exit.toCenter(false).bigToSmall(true);
        d3.select("#congreso").datum(data).call(parliament);
    }
!}

= Election Results

{!<svg id="congreso" style="width: 500px; height: 250px;"> </svg>!}
{!<div style='margin-top: -2em; width: 100%; font-style: italic; text-align: center'>!} Majority: [+ congreso_s_majority +]{!</div>!}

{!<table style='margin-left: 0.5em; display:table; width: 95%;'>!}
{!<tr><td style='min-width: 5em; font-weight: bold;'>Party</td><td style='width: 9em; text-align:center; font-weight: bold;'>Popular Vote (Cat.)</td><td style='width: 5em; font-weight: bold;'>Change</td><td style='width: 3em; text-align: right; font-weight: bold;'>Seats</td><td style='width: 3em; font-weight: bold;'>Change</td></tr>!}
[? if psoe_congreso_showviz: {!<tr><td><div class="box" style='background-color: #da291c'> </div> !} PSOE {!</td><td style='text-align: right;'>!}[+ psoe_congreso_pv +]% [? if psoe_congreso_pv_cat > 0.1 : ([+ psoe_congreso_pv_cat +]%) ?] {!</td><td>!} [+ psoe_congreso_pv_delta +] {!</td><td style='text-align: right;'>!} [+ psoe_congreso_s +] {!</td><td>!} [+ psoe_congreso_s_delta +] {!</td>!}?]
[? if pp_congreso_showviz: {!<tr><td><div class="box" style='background-color: #1d84ce'> </div> !} PP {!</td><td style='text-align: right;'>!}[+ pp_congreso_pv +]% ([+ pp_congreso_pv_cat +]%) {!</td><td>!} [+ pp_congreso_pv_delta +] {!</td><td style='text-align: right;'>!} [+ pp_congreso_s +] {!</td><td>!} [+ pp_congreso_s_delta +] {!</td>!}?]
[? if up_congreso_showviz: {!<tr><td><div class="box" style='background-color: #5a205a'> </div> !} UP {!</td><td style='text-align: right;'>!}[+ up_congreso_pv +]% ([+ up_congreso_pv_cat +]%) {!</td><td>!} [+ up_congreso_pv_delta +] {!</td><td style='text-align: right;'>!} [+ up_congreso_s +] {!</td><td>!} [+ up_congreso_s_delta +] {!</td>!}?]
[? if cs_congreso_showviz: {!<tr><td><div class="box" style='background-color: #EB6109'> </div> !} csspa {!</td><td style='text-align: right;'>!}[+ cs_congreso_pv +]% ([+ cs_congreso_pv_cat +]%) {!</td><td>!} [+ cs_congreso_pv_delta +] {!</td><td style='text-align: right;'>!} [+ cs_congreso_s +] {!</td><td>!} [+ cs_congreso_s_delta +] {!</td>!}?]
[? if vox_congreso_showviz: {!<tr><td><div class="box" style='background-color: #63be21'> </div> !} Vox {!</td><td style='text-align: right;'>!}[+ vox_congreso_pv +]% ([+ vox_congreso_pv_cat +]%) {!</td><td>!} [+ vox_congreso_pv_delta +] {!</td><td style='text-align: right;'>!} [+ vox_congreso_s +] {!</td><td>!} [+ vox_congreso_s_delta +] {!</td>!}?]
[? if podemos_congreso_showviz: {!<tr><td><div class="box" style='background-color: #9269f5'> </div> !} Podemos {!</td><td style='text-align: right;'>!}[+ podemos_congreso_pv +]% ([+ podemos_congreso_pv_cat +]%) {!</td><td>!} [+ podemos_congreso_pv_delta +] {!</td><td style='text-align: right;'>!} [+ podemos_congreso_s +] {!</td><td>!} [+ podemos_congreso_s_delta +] {!</td>!}?]
[? if mpais_congreso_showviz: {!<tr><td><div class="box" style='background-color: #027665'> </div> !} Más País {!</td><td style='text-align: right;'>!}[+ mpais_congreso_pv +]% ([+ mpais_congreso_pv_cat +]%) {!</td><td>!} [+ mpais_congreso_pv_delta +] {!</td><td style='text-align: right;'>!} [+ mpais_congreso_s +] {!</td><td>!} [+ mpais_congreso_s_delta +] {!</td>!}?]
