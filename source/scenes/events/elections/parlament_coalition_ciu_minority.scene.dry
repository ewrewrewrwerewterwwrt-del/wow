@ppc
title: [+ parlament_current_ciu +] <span style="font-style: italic;color: [? if parlament_current_ciu = 'ciu': var(--ciu)?][? if parlament_current_ciu = 'cdc': var(--cdc)?][? if parlament_current_ciu = 'dl': var(--dl)?][? if parlament_current_ciu = 'pdcat': var(--pdcat)?][? if parlament_current_ciu = 'jxcat': var(--jxcat)?][? if parlament_current_ciu = 'junts': var(--junts)?]">minority government</span> (with PPC [? if unio_parlament_s > 0: + unio?] support)
choose-if: parlament_coalition_ciu_ppc_unio_s >= parlament_s_majority and ((parlament_current_ciu == "ciu" and ciu_roadmap == 0) or (parlament_current_ciu == "pdcat" and pdcat_roadmap == 0) or (parlament_current_ciu == "cdc" and cdc_roadmap == 0) or (parlament_current_ciu == "dl" and dl_roadmap == 0) or (parlament_current_ciu == "jxcat" and jxcat_roadmap == 0) or (parlament_current_ciu == "junts" and junts_roadmap == 0)) and cat_spa_relation > 50
view-if: parlament_coalition_ciu_ppc_unio_s
unavailable-subtitle: [? if parlament_coalition_ciu_ppc_unio_s < parlament_s_majority: Not enough parliamentary support. ?][? if (parlament_current_ciu == "ciu" and ciu_roadmap == 0) or (parlament_current_ciu == "pdcat" and pdcat_roadmap == 0) or (parlament_current_ciu == "cdc" and cdc_roadmap == 0) or (parlament_current_ciu == "dl" and dl_roadmap == 0) or (parlament_current_ciu == "jxcat" and jxcat_roadmap == 0) or (parlament_current_ciu == "junts" and junts_roadmap == 0): [+ parlament_current_ciu +] has an ongoing Roadmap to Independence, which the PPC will not tolerate. ?][? if cat_spa_relation <= 50: Catalonia-Spain relations are too strained. ?]
