title: [? if erc_ciu_coalition_phase = 3: Yet another ?]ERC-[+ parlament_current_ciu +] <span style="color: var(--erc); font-style: italic;">Sovereignty</span> proposal[? if erc_ciu_coalition_phase = 2:  (revised)?][? if erc_ciu_coalition_phase = 3:  (final round)?]
subtitle: [? if erc_ciu_coalition_phase = 2: ERC-[+ parlament_current_ciu +] negotiations advance.?][? if erc_ciu_coalition_phase = 3: This is set to be the final round of ERC-[+ parlament_current_ciu +] negotiations.?]
tags: event
new-page: true
view-if: erc_ciu_coalition_phase != 0 and player_party == "erc"
on-arrival: {!
    Q.parlament_coalition_changes = false;

    Q.parlament_coalition_leverage = (Q.erc_parlament_s / Q.parlament_coalition_erc_ciu_s)*55;
    if (Q.speaker_party == "erc") {
        Q.parlament_coalition_leverage -= 10;
    }
    if (Q[Q.parlament_current_ciu + "_relations"] < 50 && Q.erc_ciu_coalition_phase == 1) {
        Q.parlament_coalition_leverage -= 50 - Q[Q.parlament_current_ciu + "_relations"];
    }

    Q.parlament_coalition_leverage += Q.erc_ciu_coalition_phase*4 - 4;

    Q.parlament_coalition_proposal_president = "erc";
!}
go-to: phase_text

@phase_text
new-page: true
go-to: parlament_coalition_setnames
set-jump: choices

[? if erc_ciu_coalition_phase = 1: As the leading force, we're expected to put forward a government composition proposal to [+ parlament_current_ciu +]. [? if parlament_coalition_changes: Right now, the proposal looks as follows: ?] ?][? if erc_ciu_coalition_phase > 1: Answering our previous proposal, [+ parlament_current_ciu +] has pushed back with a few ideas of its own on what shape this government should take. [? if parlament_coalition_changes: After our ammendments, it looks as follows: ?] ?]

@choices

- @changes
- @send_back
- @accept

@changes
title: Propose a[? if erc_ciu_coalition_phase > 1 or parlament_coalition_changes:n alternative?] Government Composition

[? if not parlament_coalition_changes: We can try to propose a different distribution of ministries, but there's no guarantee that [+ parlament_current_ciu +] will accept it. ?]

- @vp
- @economy
- @health
- @education
- @interior
- @foreign
- @territory
- @bnl
- @push_leverage_positions
- @go_back: Finish proposing changes

@go_back
on-arrival: {!
    // single partner: any position we did not claim falls to [+ parlament_current_ciu +]
    if (Q.parlament_coalition_proposal_vp != "erc") {
        Q.parlament_coalition_proposal_vp = Q.parlament_current_ciu;
    }
    var ecpositions = ["economy", "interior", "foreign", "health", "education", "territory", "bnl"];
    for (var eci = 0; eci < ecpositions.length; eci++) {
        var eckey = "parlament_coalition_proposal_" + ecpositions[eci];
        if (Q[eckey] == null) {
            Q[eckey] = Q.parlament_current_ciu;
        }
    }
!}
go-to: phase_text

@vp
title: [? if parlament_coalition_proposal_vp != "erc": Take the Vice-Presidency ?][? if parlament_coalition_proposal_vp = "erc": Give up the Vice-Presidency ?]
choose-if: (parlament_coalition_proposal_vp != "erc" and parlament_coalition_leverage >= 10 and (parlament_coalition_proposal_interior = "erc" or parlament_coalition_proposal_economy = "erc" or parlament_coalition_proposal_health = "erc" or parlament_coalition_proposal_education = "erc" or parlament_coalition_proposal_foreign = "erc" or parlament_coalition_proposal_territory = "erc" or parlament_coalition_proposal_bnl = "erc")) or (parlament_coalition_proposal_vp = "erc")
unavailable-subtitle: [? if parlament_coalition_leverage < 10: We don't have enough leverage to take the Vice-Presidency. ?][? if parlament_coalition_leverage >= 10: It's not possible for us to take *only* the Vice-Presidency. ?]
on-arrival: {!
    Q.parlament_coalition_changes = true;
    if (Q.parlament_coalition_proposal_vp != "erc") {
        Q.parlament_coalition_proposal_vp = "erc";
        Q.parlament_coalition_leverage -= 20;
    } else {
        Q.parlament_coalition_proposal_vp = null;
        Q.parlament_coalition_leverage += 20;
    }
!}
go-to: changes

[? if parlament_coalition_proposal_vp = "erc": We've added the Vice-Presidency to our proposal.?][? if parlament_coalition_proposal_vp != "erc": We've proposed giving up the Vice-Presidency to [+ parlament_current_ciu +].?]

