title: set coalition names
on-arrival: {!
    // TODO: Missing unió, pxc/fnc
    Q.parlament_coalition_proposal_president_gender = Q[Q.parlament_coalition_proposal_president + "_leader_gender"];
    Q.parlament_coalition_proposal_president_name = Q[Q.parlament_coalition_proposal_president + "_leader"];
    

    if (Q.parlament_coalition_proposal_vp == Q.parlament_coalition_proposal_president) {
        switch (Q.parlament_coalition_proposal_vp) {  
            case "ciu":
            case "cdc":
                Q.parlament_coalition_proposal_vp_name = "Neus Munté";
                Q.parlament_coalition_proposal_vp_gender = "f";
                break;
            case "dl":
                Q.parlament_coalition_proposal_vp_name = "Francesc Homs";
                Q.parlament_coalition_proposal_vp_gender = "m";
                break;
            case "pdcat":
                Q.parlament_coalition_proposal_vp_name = "Marta Pascal";
                Q.parlament_coalition_proposal_vp_gender = "f";
                break;
            case "jxcat":
                if (!Q.erc_in_jxcat) {
                    if (Q.jxcat_bcnleader == "Elsa Artadi") {
                        Q.parlament_coalition_proposal_vp_name = "Jordi Turull";
                        Q.parlament_coalition_proposal_vp_gender = "m";
                    } else {
                        Q.parlament_coalition_proposal_vp_name = "Elsa Artadi";
                        Q.parlament_coalition_proposal_vp_gender = "f";
                    }
                } else {
                    // FIXME: with ERC in JxCAT, the VP should be decided based on whatever the jxcat composition ends up being
                    Q.parlament_coalition_proposal_vp_name = "JXCAT WHO?";
                    Q.parlament_coalition_proposal_vp_gender = "?";
                }
                break;
            case "junts":
                if (Q.junts_leader == "Laura Borràs") {
                    Q.parlament_coalition_proposal_vp_name = "Jordi Sànchez";
                    Q.parlament_coalition_proposal_vp_gender = "m";
                } else {
                    Q.parlament_coalition_proposal_vp_name = "Laura Borràs";
                    Q.parlament_coalition_proposal_vp_gender = "f";
                }
                break;
            case "erc":
                if (Q.erc_leader != "Marta Rovira") {
                    Q.parlament_coalition_proposal_vp_name = "Marta Rovira";
                    Q.parlament_coalition_proposal_vp_gender = "f";
                } else {
                    Q.parlament_coalition_proposal_vp_name = "Pere Aragonès";
                    Q.parlament_coalition_proposal_vp_gender = "m";
                }
                break;
            case "psc":
                if (Q.psc_leader == "Àngel Ros") {
                    Q.parlament_coalition_proposal_vp_name = "Montserrat Tura";
                    Q.parlament_coalition_proposal_vp_gender = "f";
                } else if (Q.psc_leader == "Montserrat Tura") {
                    Q.parlament_coalition_proposal_vp_name = "Àngel Ros";
                    Q.parlament_coalition_proposal_vp_gender = "m";
                } else {
                    Q.parlament_coalition_proposal_vp_name = "Eva Granados";
                    Q.parlament_coalition_proposal_vp_gender = "f";
                }
                break;
            case Q.parlament_current_icv:
                Q.parlament_coalition_proposal_vp_name = "Gerardo Pisarello";
                Q.parlament_coalition_proposal_vp_gender = "m";
                break;
            case "cs":
                Q.parlament_coalition_proposal_vp_name = "Carlos Carrizosa";
                Q.parlament_coalition_proposal_vp_gender = "m";
                break;
            case "ppc":
                if (Q.ppc_leader == "Xavier García Albiol") {
                    Q.parlament_coalition_proposal_vp_name = "Alejandro Fernández";
                    Q.parlament_coalition_proposal_vp_gender = "m";
                } else {
                    Q.parlament_coalition_proposal_vp_name = "Xavier García Albiol";
                    Q.parlament_coalition_proposal_vp_gender = "m";
                }
                break;
            case "vox":
                Q.parlament_coalition_proposal_vp_name = "Antonio Gallego";
                Q.parlament_coalition_proposal_vp_gender = "m";
                break;
        }
    } else if (Q.parlament_coalition_proposal_vp === null) {
        Q.parlament_coalition_proposal_vp_name = "<span style='font-style: italics'>To be filled by coalition partners</span>";
        Q.parlament_coalition_proposal_vp_gender = "f";
    } else {
        Q.parlament_coalition_proposal_vp_gender = Q[Q.parlament_coalition_proposal_vp + "_leader_gender"];
        Q.parlament_coalition_proposal_vp_name = Q[Q.parlament_coalition_proposal_vp + "_leader"];
    }

    switch (Q.parlament_coalition_proposal_economy) {
        case null:
            Q.parlament_coalition_proposal_economy_name = "<span style='font-style: italics'>To be filled by coalition partners</span>";
            Q.parlament_coalition_proposal_economy_gender = "f";
            break;
        case "ciu":
        case "cdc":
        case "dl":
        case "pdcat":
        case "junts":
            if (Q.year < 2018) {
                Q.parlament_coalition_proposal_economy_name = "Andreu Mas-Colell";
                Q.parlament_coalition_proposal_economy_gender = "m";
            } else {
                Q.parlament_coalition_proposal_economy_name = "Jaume Giró";
                Q.parlament_coalition_proposal_economy_gender = "m";
            }
            break;
        case "jxcat":
            if (Q.erc_in_jxcat) {
                Q.parlament_coalition_proposal_economy_name = "Pere Aragonès";
                Q.parlament_coalition_proposal_economy_gender = "m";
            } else {
                Q.parlament_coalition_proposal_economy_name = "Jaume Giró";
                Q.parlament_coalition_proposal_economy_gender = "m";
            }
            break;
        case "erc":
            if (Q.year > 2016) {
                Q.parlament_coalition_proposal_economy_name = "Pere Aragonès";
                Q.parlament_coalition_proposal_economy_gender = "m";
            } else if (Q.parlament_coalition_proposal_vp_name != "Marta Rovira" && Q.erc_leader != "Marta Rovira") {
                Q.parlament_coalition_proposal_economy_name = "Marta Rovira";
                Q.parlament_coalition_proposal_economy_gender = "f";
            } else {
                Q.parlament_coalition_proposal_economy_name = "Josep Huguet";
                Q.parlament_coalition_proposal_economy_gender = "m";
            }
            break;
        case "psc":
            if (Q.parlament_coalition_proposal_vp_name != "Eva Granados") {
                Q.parlament_coalition_proposal_economy_name = "Eva Granados";
                Q.parlament_coalition_proposal_economy_gender = "f";
            } else {
                Q.parlament_coalition_proposal_economy_name = "Antoni Castells";
                Q.parlament_coalition_proposal_economy_gender = "m";
            }
            break;
        case "icv":
            Q.parlament_coalition_proposal_economy_name = "Marc Vidal";
            Q.parlament_coalition_proposal_economy_gender = "m";
            break;
        case "csqp":
        case "cecp":
        case "ecp":
            if (Q.parlament_coalition_proposal_vp_name != "Xavier Domènech" && Q.parlament_coalition_proposal_president_name != "Xavier Domènech") {
                Q.parlament_coalition_proposal_economy_name = "Xavier Domènech";
                Q.parlament_coalition_proposal_economy_gender = "m";
            } else {
                Q.parlament_coalition_proposal_economy_name = "Hortensia Grau";
                Q.parlament_coalition_proposal_economy_gender = "f";
            }
            break;
        case "cs":
            Q.parlament_coalition_proposal_economy_name = "José Manuel Villegas";
            Q.parlament_coalition_proposal_economy_gender = "m";
            break;
        case "ppc":
            Q.parlament_coalition_proposal_economy_name = "Manuel Reyes";
            Q.parlament_coalition_proposal_economy_gender = "m";
            break;
        case "vox":
    }

