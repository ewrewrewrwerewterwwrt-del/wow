title: resolve coalition
on-arrival: {!
    Q.president_party = Q.parlament_coalition_proposal_president;
    Q.president_gender = Q.parlament_coalition_proposal_president_gender;
    Q.president = Q.parlament_coalition_proposal_president_name;
    
    Q.vicepresident_party = Q.parlament_coalition_proposal_vp;
    Q.vicepresident = Q.parlament_coalition_proposal_vp_name;
    Q.vicepresident_gender = Q.parlament_coalition_proposal_vp_gender;
    
    Q.economy_minister_party = Q.parlament_coalition_proposal_economy;
    Q.economy_minister = Q.parlament_coalition_proposal_economy_name;
    Q.economy_minister_gender = Q.parlament_coalition_proposal_economy_gender;

    Q.interior_minister_party = Q.parlament_coalition_proposal_interior;
    Q.interior_minister = Q.parlament_coalition_proposal_interior_name;
    Q.interior_minister_gender = Q.parlament_coalition_proposal_interior_gender;

    Q.health_minister_party = Q.parlament_coalition_proposal_health;
    Q.health_minister = Q.parlament_coalition_proposal_health_name;
    Q.health_minister_gender = Q.parlament_coalition_proposal_health_gender;

    Q.education_minister_party = Q.parlament_coalition_proposal_education;
    Q.education_minister = Q.parlament_coalition_proposal_education_name;
    Q.education_minister_gender = Q.parlament_coalition_proposal_education_gender;

    Q.territory_minister_party = Q.parlament_coalition_proposal_territory;
    Q.territory_minister = Q.parlament_coalition_proposal_territory_name;
    Q.territory_minister_gender = Q.parlament_coalition_proposal_territory_gender;

    Q.foreign_minister_party = Q.parlament_coalition_proposal_foreign;
    Q.foreign_minister = Q.parlament_coalition_proposal_foreign_name;
    Q.foreign_minister_gender = Q.parlament_coalition_proposal_foreign_gender;

    Q.bnl_minister_party = Q.parlament_coalition_proposal_bnl;
    Q.bnl_minister = Q.parlament_coalition_proposal_bnl_name;
    Q.bnl_minister_gender = Q.parlament_coalition_proposal_bnl_gender;

    Q.cat_caretaker_gov = false;

    Q.historical_event = "We have a new government in the Generalitat! President " + Q.president + " will lead a " + Q.cat_coalition_disp + " for this legistlature.";
!}
go-to: post_event