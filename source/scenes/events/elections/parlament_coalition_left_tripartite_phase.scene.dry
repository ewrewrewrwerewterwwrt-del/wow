title: Putting together [? if left_tripartite_coalition_phase = 3: yet another ?][?if left_tripartite_coalition_phase <2 : a?] [? if left_tripartite_coalition_phase = 2: a new ?] ERC - PSC -[+ parlament_current_icv +] coalition proposal 
subtitle: [? if left_tripartite_coalition_phase = 2: <span style="color: var(--erc); font-style: italic;">Left</span> <span style="color: [? if parlament_current_icv = 'icv': var(--icv)?][? if parlament_current_icv = 'csqp': var(--csqp)?][? if parlament_current_icv = 'cecp': var(--cecp)?][? if parlament_current_icv = 'ecp': var(--ecp)?]; font-style: italic;">Tri</span><span style='color: var(--psc); font-style: italic;'>partite</span> negotiations advance.?][? if left_tripartite_coalition_phase = 3: This is set to be the final round of <span style="color: var(--erc); font-style: italic;">Left</span> <span style="color: [? if parlament_current_icv = 'icv': var(--icv)?][? if parlament_current_icv = 'csqp': var(--csqp)?][? if parlament_current_icv = 'cecp': var(--cecp)?][? if parlament_current_icv = 'ecp': var(--ecp)?]; font-style: italic;">Tri</span><span style='color: var(--psc); font-style: italic;'>partite</span> negotiations.?]
tags: event
new-page: true
view-if: left_tripartite_coalition_phase != 0 and player_party == "erc"
on-arrival: {!    
    Q.parlament_coalition_changes = false;
    
    Q.parlament_coalition_leverage = (Q.erc_parlament_s / Q.parlament_coalition_erc_psc_icv_s)*55;
    if (Q.speaker_party == "erc") {
        Q.parlament_coalition_leverage -= 10;
    }

    if (Q.psc_relations < 50 && Q.left_tripartite_coalition_phase == 1) {
        Q.parlament_coalition_leverage -= 50-Q.psc_relations;
    }
    if (Q.parlament_current_icv_relations <= 55 && Q.left_tripartite_coalition_phase == 1) {
        Q.parlament_coalition_leverage -= 50-Q.psc_relations;
    }
    
    Q.parlament_coalition_leverage += Q.left_tripartite_coalition_phase*4 - 4;

    Q.parlament_coalition_proposal_president = "erc";
!}
go-to: phase_text

@phase_text
new-page: true
go-to: parlament_coalition_setnames
set-jump: choices 

[? if left_tripartite_coalition_phase = 1: As the leading force of the coalition, we're expected to make a government composition proposal to the PSC and [+ parlament_current_icv +]. [? if parlament_coalition_changes: Right now, the proposal looks as follows: ?] ?][? if left_tripartite_coalition_phase > 1: Answering to our previous proposal, PSC and [+ parlament_current_icv +] have pushed back with a few ideas of their own on what shape this coalition government should take. [? if parlament_coalition_changes: After our ammendmends, it looks as follows: ?] ?]

@choices

- @changes
- @send_back
- @accept

@changes
title: Propose a[? if left_tripartite_coalition_phase > 1 or parlament_coalition_changes:n alternative?] Government Composition

[? if not parlament_coalition_changes: We can try to propose a different distribution of ministries, but there's no guarantee that it will be accepted. ?]

- @vp
- @economy
- @health
- @education
- @interior
- @foreign
- @territory
- @bnl
- @push_leverage_positions
- @go_back: Finish proposing changes

@go_back
on-arrival: {!
    var psc_leverage = (Q.psc_parlament_s / Q.parlament_coalition_erc_psc_icv_s)*55 - 3 + Q.left_tripartite_coalition_phase;
    var icv_leverage = (Q.parlament_current_icv_s / Q.parlament_coalition_erc_psc_icv_s)*55 - 3 + Q.left_tripartite_coalition_phase;

    // the partner holding the Speaker has spent capital there, so less pull on ministries
    if (Q.speaker_party == "psc") psc_leverage -= 10;
    if (Q.speaker_party == Q.parlament_current_icv) icv_leverage -= 10;

    var empty_positions = [];
    if (Q.parlament_coalition_proposal_vp != "erc") {
        if (Q.parlament_current_icv_s > Q.psc_parlament_s) {
            Q.parlament_coalition_proposal_vp = Q.parlament_current_icv;
        } else {
            Q.parlament_coalition_proposal_vp = "psc";
        }
    }
    switch (Q.parlament_coalition_proposal_economy) {
        case null:
            empty_positions.push("economy");
            break;
        case "psc":
            psc_leverage -= 10;
            break;
        case Q.parlament_current_icv:
            psc_leverage -= 10;
            break;
        default:
            break;
    }
    switch (Q.parlament_coalition_proposal_interior) {
        case null:
            empty_positions.push("interior");
            break;
        case "psc":
            psc_leverage -= 10;
            break;
        case Q.parlament_current_icv:
            psc_leverage -= 10;
            break;
        default:
            break;
    }
    switch (Q.parlament_coalition_proposal_foreign) {
        case null:
            empty_positions.push("foreign");
            break;
        case "psc":
            psc_leverage -= 6;
            break;
        case Q.parlament_current_icv:
            psc_leverage -= 6;
            break;
        default:
            break;
    }
    switch (Q.parlament_coalition_proposal_health) {
        case null:
            empty_positions.push("health");
            break;
        case "psc":
            psc_leverage -= 7;
            break;
        case Q.parlament_current_icv:
            psc_leverage -= 7;
            break;
        default:
            break;
    }
    switch (Q.parlament_coalition_proposal_education) {
        case null:
            empty_positions.push("education");
            break;
        case "psc":
            psc_leverage -= 7;
            break;
        case Q.parlament_current_icv:
            psc_leverage -= 7;
            break;
        default:
            break;
    }
    switch (Q.parlament_coalition_proposal_territory) {
        case null:
            empty_positions.push("territory");
            break;
        case "psc":
            psc_leverage -= 5;
            break;
        case Q.parlament_current_icv:
            psc_leverage -= 5;
            break;
        default:
            break;
    }
    switch (Q.parlament_coalition_proposal_bnl) {
        case null:
            empty_positions.push("bnl");
            break;
        case "psc":
            psc_leverage -= 5;
            break;
        case Q.parlament_current_icv:
            psc_leverage -= 5;
            break;
        default:
            break;
    }

    while (empty_positions.length !== 0) {
        let random_pos = empty_positions[Math.floor(Math.random()*empty_positions.length)];
        if (psc_leverage >= icv_leverage) {
            if (empty_positions.includes("interior") && psc_leverage >= 10) {
                Q.parlament_coalition_proposal_interior = "psc";
                psc_leverage -= 10;
                empty_positions = empty_positions.filter(pos => pos != "interior");
            } else if (empty_positions.includes("economy") && psc_leverage >= 10) {
                Q.parlament_coalition_proposal_economy = "psc";
                psc_leverage -= 10;
                empty_positions = empty_positions.filter(pos => pos != "economy");
            } else if (empty_positions.includes("health") && psc_leverage >= 7) {
                Q.parlament_coalition_proposal_health= "psc";
                psc_leverage -= 7;
                empty_positions = empty_positions.filter(pos => pos != "health");
            } else {
                Q["parlament_coalition_proposal_" + random_pos] = "psc";
                psc_leverage -= 7; // weighted equally, whatever
                empty_positions = empty_positions.filter(pos => pos != random_pos);
            } 
        } else {
            if (empty_positions.includes("education") && icv_leverage >= 10) {
                Q.parlament_coalition_proposal_education = Q.parlament_current_icv;
                icv_leverage -= 10;
                empty_positions = empty_positions.filter(pos => pos != "education");
            } else if (empty_positions.includes("territory") && icv_leverage >= 7) {
                Q.parlament_coalition_proposal_territory = Q.parlament_current_icv;
                icv_leverage -= 7;
                empty_positions = empty_positions.filter(pos => pos != "territory");
            } else if (empty_positions.includes("bnl") && icv_leverage >= 5) {
                Q.parlament_coalition_proposal_bnl = Q.parlament_current_icv;
                icv_leverage -= 5;
                empty_positions = empty_positions.filter(pos => pos != "bnl");
            } else {
                Q["parlament_coalition_proposal_" + random_pos] = Q.parlament_current_icv;
                icv_leverage -= 7; // weighted equally, whatever
                empty_positions = empty_positions.filter(pos => pos != random_pos);
            } 
        }
    }
!}
go-to:phase_text

@vp
title: [? if parlament_coalition_proposal_vp != "erc": Take the Vice-Presidency ?][? if parlament_coalition_proposal_vp = "erc": Give up the Vice-Presidency ?]
choose-if: (parlament_coalition_proposal_vp != "erc" and parlament_coalition_leverage >= 10 and (parlament_coalition_proposal_interior = "erc" or parlament_coalition_proposal_economy = "erc" or parlament_coalition_proposal_health = "erc" or parlament_coalition_proposal_education = "erc" or parlament_coalition_proposal_foreign = "erc" or parlament_coalition_proposal_territory = "erc" or parlament_coalition_proposal_bnl = "erc")) or (parlament_coalition_proposal_vp = "erc")
unavailable-subtitle: [? if parlament_coalition_leverage < 10: We don't have enough leverage to take the Vice-Presidency. ?][? if parlament_coalition_leverage >= 10: It's not possible for us to take *only* the Vice-Presidency. ?]
