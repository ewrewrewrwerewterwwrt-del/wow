title: [? if ciu_erc_coalition_phase = 3: Yet another ?][+ parlament_current_ciu +][?if ciu_erc_coalition_phase <2 : 's?] [? if ciu_erc_coalition_phase = 2: new ?] coalition proposal 
subtitle: [? if ciu_erc_coalition_phase = 2: [+ parlament_current_ciu +]-ERC coalition negotiations advance.?][? if ciu_erc_coalition_phase = 3: This is set to be the final round of [+ parlament_current_ciu +]-ERC negotiations.?]
tags: event
new-page: true
view-if: ciu_erc_coalition_phase != 0 and player_party == "erc"
on-arrival: {!    
    Q.parlament_coalition_changes = false;
    Q.parlament_coalition_concessions_social = 0;
    Q.parlament_coalition_concessions_indy = 0;
    Q.parlament_coalition_concessions = false;
    
    Q.parlament_coalition_leverage = Math.max(10, 30 - (Q.parlament_current_ciu_s - Q.erc_parlament_s));
    if (Q.speaker_party == Q.parlament_current_ciu) {
        if (Q.parlament_current_ciu_s > 40) {
            Q.parlament_coalition_leverage += 3;
        } else {
            Q.parlament_coalition_leverage += 10;
        }
    } else {
        if (Q.parlament_current_ciu_s > 40) {
            Q.parlament_coalition_leverage -= 10;
        } else {
            Q.parlament_coalition_leverage -= 5;
        }
    }

    if (Q.parlament_coalition_push == 1) {
        Q.parlament_coalition_leverage += 4;
    } else if (Q.parlament_coalition_push == 2) {
        Q.parlament_coalition_leverage += 8;
    }

    var ciu_proposal_leverage = Q.parlament_coalition_leverage - 3 + Q.ciu_erc_coalition_phase;

    Q.parlament_coalition_proposal_president = Q.parlament_current_ciu;
    if (Q.parlament_coalition_leverage > 20) {
        Q.parlament_coalition_proposal_vp = "erc";
        ciu_proposal_leverage -= 20;
    } else {
        Q.parlament_coalition_proposal_vp = Q.parlament_current_ciu;
    }
    Q.parlament_coalition_proposal_interior = Q.parlament_current_ciu;
    Q.parlament_coalition_proposal_economy = Q.parlament_current_ciu;
    Q.parlament_coalition_proposal_foreign = Q.parlament_current_ciu;
    Q.parlament_coalition_proposal_health = Q.parlament_current_ciu;
    Q.parlament_coalition_proposal_education = Q.parlament_current_ciu;
    Q.parlament_coalition_proposal_territory = Q.parlament_current_ciu;
    Q.parlament_coalition_proposal_bnl = Q.parlament_current_ciu;

    if (Q[Q.parlament_current_ciu + "_roadmap"] < 3 && Q[Q.parlament_current_ciu + "_roadmap"] > 0 && ciu_proposal_leverage > 7) {
        Q.parlament_coalition_concessions_indy = 1;
        switch (Q[Q.parlament_current_ciu + "_roadmap"]) {
            case 1:
                if (Q.referendum_held) {
                    Q.parlament_coalition_concessions_indy_text = "The government commits to respect the results of the Independence Referendum and defend its results, even if it goes beyond the limits of possible negotiations with the Spanish government.";
                } else {
                    Q.parlament_coalition_concessions_indy_text = "The government commits to holding an independence consultation within the legislature's mandate.";
                }
                break;
            case 2:
                if (Q.referendum_held) {
                    Q.parlament_coalition_concessions_indy_text = "The government commits to respect the results of the Independence Referendum and defend its results, being open to unilateraly declaring independence if there's no other choice.";
                } else {
                    Q.parlament_coalition_concessions_indy_text = "The government commits to holding a binding independence referendum within the legislature's mandate.";
                }
                break;
        }
        ciu_proposal_leverage -= 2;
    }

    if (Q.parlament_coalition_proposal_bnl != "erc" && ciu_proposal_leverage > 5) {
        Q.parlament_coalition_proposal_bnl = "erc";
        ciu_proposal_leverage -= 5;
    }
    if (Q.parlament_coalition_proposal_territory != "erc" && ciu_proposal_leverage > 5) {
        Q.parlament_coalition_proposal_territory = "erc";
        ciu_proposal_leverage -= 5;
    }
    if (Q.parlament_coalition_proposal_education != "erc" && ciu_proposal_leverage > 7) {
        Q.parlament_coalition_proposal_education = "erc";
        ciu_proposal_leverage -= 7;
    }
    if (Q.parlament_coalition_proposal_health != "erc" && ciu_proposal_leverage > 7) {
        Q.parlament_coalition_proposal_health = "erc";
        ciu_proposal_leverage -= 7;
    }
    if (Q.parlament_coalition_proposal_foreign != "erc" && ciu_proposal_leverage > 6) {
        Q.parlament_coalition_proposal_foreign = "erc";
        ciu_proposal_leverage -= 6;
    }

    Q.parlament_coalition_leverage = ciu_proposal_leverage + 3 - Q.ciu_erc_coalition_phase;
!}
go-to: phase_text

@phase_text
new-page: true
go-to: parlament_coalition_setnames
set-jump: choices

[? if not parlament_coalition_changes: The representatives of [+ parlament_current_ciu +] have come forward with a [?if ciu_erc_coalition_phase > 1: new?] proposal for the formation of a new coalition government: ?][? if parlament_coalition_changes: After our ammendments, the proposal for the formation of a new coalition government looks like this: ?]

@choices


[? if parlament_coalition_concessions_social or parlament_coalition_concessions_indy: **Policy Concessions**?]

[? if parlament_coalition_concessions_social: - We've added policy requirements pushing for less austerity and more social spending to our proposal.?]

[? if parlament_coalition_concessions_indy: - [+ parlament_coalition_concessions_indy_text +] ?]

[? if not parlament_coalition_concessions: Even if we accept this proposal, we can still negotiate policy concessions.?]

