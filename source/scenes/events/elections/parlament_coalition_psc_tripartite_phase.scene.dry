title: [? if psc_tripartite_coalition_phase = 1: PSC's New Tripartite coalition proposal?][? if psc_tripartite_coalition_phase = 2: A revised PSC coalition proposal?][? if psc_tripartite_coalition_phase = 3: Final round of tripartite negotiations?]
subtitle: [? if psc_tripartite_coalition_phase = 1: The PSC has submitted a government formation proposal to ERC and [+ parlament_current_icv +].?][? if psc_tripartite_coalition_phase = 2: PSC-ERC-[+ parlament_current_icv +] government negotiations advance.?][? if psc_tripartite_coalition_phase = 3: This is the final round of negotiations.?]
tags: event
new-page: true
view-if: psc_tripartite_coalition_phase != 0 and player_party == "erc"
on-arrival: {!
    Q.parlament_coalition_changes = false;

    Q.parlament_coalition_leverage = Math.max(10, (Q.erc_parlament_s / Q.parlament_coalition_psc_erc_icv_s) * 55);
    if (Q.speaker_party == "erc") {
        Q.parlament_coalition_leverage += 5;
    }
    if (Q.parlament_coalition_push == 1) {
        Q.parlament_coalition_leverage += 4;
    } else if (Q.parlament_coalition_push >= 2) {
        Q.parlament_coalition_leverage += 8;
    }
    Q.parlament_coalition_leverage += Q.psc_tripartite_coalition_phase * 2;

    // PSC's initial proposal: PSC takes everything
    Q.parlament_coalition_proposal_president = "psc";
    Q.parlament_coalition_proposal_vp = "psc";
    Q.parlament_coalition_proposal_interior = "psc";
    Q.parlament_coalition_proposal_economy = "psc";
    Q.parlament_coalition_proposal_foreign = "psc";
    Q.parlament_coalition_proposal_health = "psc";
    Q.parlament_coalition_proposal_education = "psc";
    Q.parlament_coalition_proposal_territory = "psc";
    Q.parlament_coalition_proposal_bnl = "psc";

    // ICV gets a natural share based on seat proportion
    var icv_natural = (Q.parlament_current_icv_s / Q.parlament_coalition_psc_erc_icv_s) * 55;
    if (icv_natural > 7) {
        Q.parlament_coalition_proposal_education = Q.parlament_current_icv;
        icv_natural -= 7;
    }
    if (icv_natural > 5) {
        Q.parlament_coalition_proposal_territory = Q.parlament_current_icv;
        icv_natural -= 5;
    }
    if (icv_natural > 5) {
        Q.parlament_coalition_proposal_bnl = Q.parlament_current_icv;
        icv_natural -= 5;
    }

    // PSC offers ERC positions based on ERC's leverage
    var erc_claim = Q.parlament_coalition_leverage - 3 + Q.psc_tripartite_coalition_phase;

    if (erc_claim > 6) {
        Q.parlament_coalition_proposal_foreign = "erc";
        erc_claim -= 6;
    }
    if (erc_claim > 5) {
        Q.parlament_coalition_proposal_bnl = "erc";
        erc_claim -= 5;
    }
    if (erc_claim > 7) {
        Q.parlament_coalition_proposal_health = "erc";
        erc_claim -= 7;
    }
    if (erc_claim > 10) {
        Q.parlament_coalition_proposal_interior = "erc";
        erc_claim -= 10;
    }

    Q.parlament_coalition_leverage = erc_claim + 3 - Q.psc_tripartite_coalition_phase;
!}
go-to: phase_text

@phase_text
new-page: true
go-to: parlament_coalition_setnames
set-jump: choices

[? if psc_tripartite_coalition_phase = 1: The PSC's negotiators have come forward with a proposal for forming a New Tripartite government.  ?][? if psc_tripartite_coalition_phase > 1: After our counter-proposal, the PSC has submitted a revised offer. ?][? if parlament_coalition_changes: After our adjustments, the current position looks as follows: ?]

@choices

- @changes
- @send_back
- @accept

@changes
title: Propose an alternative Government Composition

[? if not parlament_coalition_changes: We can try to demand or give up ministries before sending a counter-proposal to the PSC. Unclaimed positions will be distributed between PSC and [+ parlament_current_icv +]. ?]

- @vp
- @economy
- @health
- @education
- @interior
- @foreign
- @territory
- @bnl
- @push_leverage_positions
- @go_back: Finish proposing changes

@go_back
on-arrival: {!
    var psc_leverage = (Q.psc_parlament_s / Q.parlament_coalition_psc_erc_icv_s) * 55 + 8 - 3 * Q.psc_tripartite_coalition_phase;
    var icv_leverage = (Q.parlament_current_icv_s / Q.parlament_coalition_psc_erc_icv_s) * 55 + 8 - 3 * Q.psc_tripartite_coalition_phase;

    var empty_positions = [];
    if (Q.parlament_coalition_proposal_vp == null)        empty_positions.push("vp");
    if (Q.parlament_coalition_proposal_economy == null)    empty_positions.push("economy");
    if (Q.parlament_coalition_proposal_interior == null)   empty_positions.push("interior");
    if (Q.parlament_coalition_proposal_foreign == null)    empty_positions.push("foreign");
    if (Q.parlament_coalition_proposal_health == null)     empty_positions.push("health");
    if (Q.parlament_coalition_proposal_education == null)  empty_positions.push("education");
    if (Q.parlament_coalition_proposal_territory == null)  empty_positions.push("territory");
    if (Q.parlament_coalition_proposal_bnl == null)        empty_positions.push("bnl");

    while (empty_positions.length > 0) {
        var pos = empty_positions[0];
        if (psc_leverage >= icv_leverage) {
            if (empty_positions.includes("interior") && psc_leverage >= 10) {
                Q.parlament_coalition_proposal_interior = "psc";
                psc_leverage -= 10;
                empty_positions = empty_positions.filter(p => p != "interior");
            } else if (empty_positions.includes("economy") && psc_leverage >= 10) {
                Q.parlament_coalition_proposal_economy = "psc";
                psc_leverage -= 10;
                empty_positions = empty_positions.filter(p => p != "economy");
            } else if (empty_positions.includes("health") && psc_leverage >= 7) {
                Q.parlament_coalition_proposal_health = "psc";
                psc_leverage -= 7;
                empty_positions = empty_positions.filter(p => p != "health");
            } else if (empty_positions.includes("vp") && psc_leverage >= 20) {
                Q.parlament_coalition_proposal_vp = "psc";
                psc_leverage -= 20;
                empty_positions = empty_positions.filter(p => p != "vp");
            } else {
                Q["parlament_coalition_proposal_" + pos] = "psc";
                psc_leverage -= 5;
                empty_positions = empty_positions.filter(p => p != pos);
            }
        } else {
            if (empty_positions.includes("education") && icv_leverage >= 7) {
                Q.parlament_coalition_proposal_education = Q.parlament_current_icv;
                icv_leverage -= 7;
                empty_positions = empty_positions.filter(p => p != "education");
            } else if (empty_positions.includes("territory") && icv_leverage >= 5) {
                Q.parlament_coalition_proposal_territory = Q.parlament_current_icv;
                icv_leverage -= 5;
                empty_positions = empty_positions.filter(p => p != "territory");
            } else if (empty_positions.includes("bnl") && icv_leverage >= 5) {
                Q.parlament_coalition_proposal_bnl = Q.parlament_current_icv;
                icv_leverage -= 5;
                empty_positions = empty_positions.filter(p => p != "bnl");
            } else if (empty_positions.includes("vp") && icv_leverage >= 20) {
                Q.parlament_coalition_proposal_vp = Q.parlament_current_icv;
                icv_leverage -= 20;
                empty_positions = empty_positions.filter(p => p != "vp");
            } else {
                Q["parlament_coalition_proposal_" + pos] = Q.parlament_current_icv;
                icv_leverage -= 5;
                empty_positions = empty_positions.filter(p => p != pos);
            }
        }
    }
!}
go-to: phase_text

@vp
title: [? if parlament_coalition_proposal_vp != "erc": Demand the Vice-Presidency ?][? if parlament_coalition_proposal_vp = "erc": Give up the Vice-Presidency ?]
choose-if: (parlament_coalition_proposal_vp != "erc" and parlament_coalition_leverage >= 10 and erc_parlament_s > parlament_current_icv_s) or (parlament_coalition_proposal_vp = "erc")
unavailable-subtitle: [? if erc_parlament_s <= parlament_current_icv_s: [+ parlament_current_icv +] is a larger partner, the Vice-Presidency is reserved for them. ?][? if parlament_coalition_leverage < 10: We don't have enough leverage to demand the Vice-Presidency. ?]
on-arrival: {!
    Q.parlament_coalition_changes = true;
    if (Q.parlament_coalition_proposal_vp != "erc") {
        Q.parlament_coalition_proposal_vp = "erc";
        Q.parlament_coalition_leverage -= 20;
    } else {
        Q.parlament_coalition_proposal_vp = null;
        Q.parlament_coalition_leverage += 20;
    }
!}
go-to: changes

[? if parlament_coalition_proposal_vp = "erc": We've added the Vice-Presidency to our counter-proposal.?][? if parlament_coalition_proposal_vp != "erc": We've released the Vice-Presidency.?]

