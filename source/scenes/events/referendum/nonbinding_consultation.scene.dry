@convoluted
title: Do you want Catalonia to exercise its right to self-determination and accede to full sovereignty, on the condition a new understanding of the relationship between Catalonia and Spain is first offered and negotiated with the Spanish State?
view-if: consultation_question = 3
on-arrival: {!
    Q.consultation_yes = 0;
    Q.consultation_abst = 0;
    Q.consultation_no = 0;

    for (var constituency of Q.parlament_constituencies) {
        for (var demo of Q.parlament_demographics) {
            Q.consultation_yes += (Q["ciu_parlament_" + constituency + "_" + demo + "_support"] * 0.9 + Q["cdc_parlament_" + constituency + "_" + demo + "_support"] + Q["dl_parlament_" + constituency + "_" + demo + "_support"] + Q["pdcat_parlament_" + constituency + "_" + demo + "_support"] + Q["jxcat_parlament_" + constituency + "_" + demo + "_support"] + Q["junts_parlament_" + constituency + "_" + demo + "_support"] + Q["jxsi_parlament_" + constituency + "_" + demo + "_support"] + Q["erc_parlament_" + constituency + "_" + demo + "_support"] + Q["cup_parlament_" + constituency + "_" + demo + "_support"] + Q["fnc_parlament_" + constituency + "_" + demo + "_support"] + (Q["icv_parlament_" + constituency + "_" + demo + "_support"] + Q["csqp_parlament_" + constituency + "_" + demo + "_support"]) * 0.4 + Q["cecp_parlament_" + constituency + "_" + demo + "_support"] * 0.1) * Q["parlament_" + constituency + "_" + demo + "_pop"]/100;
            Q.consultation_no += (Q["ciu_parlament_" + constituency + "_" + demo + "_support"] * 0.1 + Q["unio_parlament_" + constituency + "_" + demo + "_support"] + (Q["icv_parlament_" + constituency + "_" + demo + "_support"] + Q["csqp_parlament_" + constituency + "_" + demo + "_support"]) * 0.4 + Q["cecp_parlament_" + constituency + "_" + demo + "_support"] * 0.6) * Q["parlament_" + constituency + "_" + demo + "_pop"]/100;
            Q.consultation_abst += ((Q["icv_parlament_" + constituency + "_" + demo + "_support"] + Q["csqp_parlament_" + constituency + "_" + demo + "_support"]) * 0.2 +  Q["cecp_parlament_" + constituency + "_" + demo + "_support"] * 0.3 +  Q["ppc_parlament_" + constituency + "_" + demo + "_support"] + Q["cs_parlament_" + constituency + "_" + demo + "_support"] + Q["vox_parlament_" + constituency + "_" + demo + "_support"] + Q["abstain_parlament_" + constituency + "_" + demo + "_support"]) * Q["parlament_" + constituency + "_" + demo + "_pop"]/100;
            switch (Q.psc_leader) {
                case "Àngel Ros":
                    Q.consultation_abst += (Q["psc_parlament_" + constituency + "_" + demo + "_support"] * 0.4)* Q["parlament_" + constituency + "_" + demo + "_pop"]/100;
                    Q.consultation_no += (Q["psc_parlament_" + constituency + "_" + demo + "_support"] * 0.4)* Q["parlament_" + constituency + "_" + demo + "_pop"]/100;
                    Q.consultation_yes += (Q["psc_parlament_" + constituency + "_" + demo + "_support"] * 0.2)* Q["parlament_" + constituency + "_" + demo + "_pop"]/100;
                    break;
                case "Montserrat Tura":
                    Q.consultation_abst += (Q["psc_parlament_" + constituency + "_" + demo + "_support"] * 0.3)* Q["parlament_" + constituency + "_" + demo + "_pop"]/100;
                    Q.consultation_no += (Q["psc_parlament_" + constituency + "_" + demo + "_support"] * 0.4)* Q["parlament_" + constituency + "_" + demo + "_pop"]/100;
                    Q.consultation_yes += (Q["psc_parlament_" + constituency + "_" + demo + "_support"] * 0.3)* Q["parlament_" + constituency + "_" + demo + "_pop"]/100;
                    break;
                default:
                    Q.consultation_abst += (Q["psc_parlament_" + constituency + "_" + demo + "_support"] * 0.85)* Q["parlament_" + constituency + "_" + demo + "_pop"]/100;
                    Q.consultation_no += (Q["psc_parlament_" + constituency + "_" + demo + "_support"] * 0.1)* Q["parlament_" + constituency + "_" + demo + "_pop"]/100;
                    Q.consultation_yes += (Q["psc_parlament_" + constituency + "_" + demo + "_support"] * 0.05)* Q["parlament_" + constituency + "_" + demo + "_pop"]/100;
                    break;
            }            
        }
    }
    // Apply penalty for shitty af question
    Q.consultation_yes = Math.ceil(Q.consultation_yes * 0.7);
    Q.consultation_abst = Math.ceil(Q.consultation_abst + Q.consultation_yes *0.3 + Q.consultation_no * 0.5);
    Q.consultation_no = Math.ceil(Q.consultation_no * 0.5);

    Q.consultation_total_votes = Q.consultation_no + Q.consultation_yes;
    Q.consultation_participation_pc = Math.round((Q.consultation_total_votes/ (Q.consultation_total_votes + Q.consultation_abst)) * 1000) / 10;
    Q.consultation_yes_pc = Math.round((Q.consultation_yes / Q.consultation_total_votes) * 1000) / 10;
    Q.consultation_no_pc = Math.round((Q.consultation_no / Q.consultation_total_votes) * 1000) / 10;

    // Add thousands notation
    Q.consultation_yes = Q.consultation_yes.toString().replace(/\B(?=(\d{3})+(?!\d))/g, '.');
    Q.consultation_no = Q.consultation_no.toString().replace(/\B(?=(\d{3})+(?!\d))/g, '.');
!}


**Do you want Catalonia to exercise its right to self-determination and accede to full sovereignty, on the condition a new understanding of the relationship between Catalonia and Spain is first offered and negotiated with the Spanish State?**

