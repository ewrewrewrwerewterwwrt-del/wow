[? if ppc_parlament_s > 0 : <div style="margin-bottom:0.75em; display: flex; gap: 0.7em;"><div style="flex: 0 0 15%;align-content:center;"><img style="max-width:200%;margin-left:-50%" src="img/parties/logo_pp.png"></div><div style="flex: 1 1 85%;"><p style="margin-top:-0.25em; margin-bottom:0em;"><span style="color: #007fff; font-weight: bold;">PPC</span> - [+ ppc_relations : relationships +]</p><p style="max-width:100%;margin-bottom:0em;font-size:0.8em;">[+ ppc_leader +] <span style="font-style:italic;">([+ ppc_ideology +])</span></p></div></div> ?]
[? if vox_parlament_s > 0 : <div style="margin-bottom:0.75em; display: flex; gap: 0.7em;"><div style="flex: 0 0 15%;align-content:center;"><img style="width:fit-content;" src="img/parties/logo_vox.svg"></div><div style="flex: 1 1 85%;"><p style="margin-top:-0.25em; margin-bottom:0em;"><span style="color: #63be21; font-weight: bold;">VOX</span> - [+ vox_relations : relationships +]</p><p style="max-width:100%;margin-bottom:0em;font-size:0.8em;">[+ vox_leader +] <span style="font-style:italic;">([+ vox_ideology +])</span></p></div></div> ?]
[? if icv_parlament_s > 0 : <div style="margin-bottom:0.75em; display: flex; gap: 0.7em;"><div style="flex: 0 0 15%;align-content:center;"><img style="width:fit-content;" src="img/parties/logo_icv.svg"></div><div style="flex: 1 1 85%;"><p style="margin-top:-0.25em; margin-bottom:0em;"><span style="color: #67af2f; font-weight: bold;">ICV-EUiA</span> - [+ icv_relations : relationships +]</p><p style="max-width:100%;margin-bottom:0em;font-size:0.8em;">[+ icv_leader +] <span style="font-style:italic;">([+ icv_ideology +])</span></p></div></div> ?]
[? if csqp_parlament_s > 0 : <div style="margin-bottom:0.75em; display: flex; gap: 0.7em;"><div style="flex: 0 0 15%;align-content:center;"><img style="width:fit-content;" src="img/parties/logo_csqp.png"></div><div style="flex: 1 1 85%;"><p style="margin-top:-0.25em; margin-bottom:0em;"><span style="color: #c3113b; font-weight: bold;">CSQP</span> - [+ csqp_relations : relationships +]</p><p style="max-width:100%;margin-bottom:0em;font-size:0.8em;">[+ csqp_leader +] <span style="font-style:italic;">([+ csqp_ideology +])</span></p></div></div> ?]
[? if cecp_parlament_s > 0 : <div style="margin-bottom:0.75em; display: flex; gap: 0.7em;"><div style="flex: 0 0 15%;align-content:center;"><img src="img/parties/logo_cecp.svg"></div><div style="flex: 1 1 85%;"><p style="margin-top:-0.25em; margin-bottom:0em;"><span style="color: #be3882; font-weight: bold;">CECP</span> - [+ cecp_relations : relationships +]</p><p style="max-width:100%;margin-bottom:0em;font-size:0.8em;">[+ cecp_leader +] <span style="font-style:italic;">([+ cecp_ideology +])</span></p></div></div> ?]
[? if ecp_parlament_s > 0 : <div style="margin-bottom:0.75em; display: flex; gap: 0.7em;"><div style="flex: 0 0 15%;align-content:center;"><img src="img/parties/logo_ecp.svg"></div><div style="flex: 1 1 85%;"><p style="margin-top:-0.25em; margin-bottom:0em;"><span style="color: #6e236e; font-weight: bold;">ECP</span> - [+ ecp_relations : relationships +]</p><p style="max-width:100%;margin-bottom:0em;font-size:0.8em;">[+ ecp_leader +] <span style="font-style:italic;">([+ ecp_ideology +])</span></p></div></div> ?]
[? if (player_party != "cup") and (cup_parlament_s > 0): <div style="margin-bottom:0.75em; display: flex; gap: 0.7em;"><div style="flex: 0 0 15%;align-content:center;"><img style="width:fit-content; border-radius: 5px;" src="img/parties/logo_cup.svg"></div><div style="flex: 1 1 85%;"><p style="margin-top:-0.25em; margin-bottom:0em;"><span style="color: #C4B156; font-weight: bold;">CUP</span> - [+ cup_relations : relationships +]</p><p style="max-width:100%;margin-bottom:0em;font-size:0.8em;">[+ cup_leader +] <span style="font-style:italic;">([+ cup_ideology +])</span></p></div></div> ?]
[? if unio_parlament_s > 0 : <div style="margin-bottom:0.75em; display: flex; gap: 0.7em;"><div style="flex: 0 0 15%;align-content:center;"><img style="width:fit-content;" src="img/parties/logo_unio.png"></div><div style="flex: 1 1 85%;"><p style="margin-top:-0.25em; margin-bottom:0em;"><span style="color: #0052a3; font-weight: bold;">UDC</span> - [+ unio_relations : relationships +]</p><p style="max-width:100%;margin-bottom:0em;font-size:0.8em;">[+ unio_leader +] <span style="font-style:italic;">([+ unio_ideology +])</span></p></div></div> ?]
[? if pxc_parlament_s > 0 : <div style="margin-bottom:0.75em; display: flex; gap: 0.7em;"><div style="flex: 0 0 15%;align-content:center;"><img style="width:fit-content; border: 1px solid black; border-radius: 5px;" src="img/parties/logo_pxc.gif"></div><div style="flex: 1 1 85%;"><p style="margin-top:-0.25em; margin-bottom:0em;"><span style="color: #00FFFF; font-weight: bold;">PxC</span> - [+ pxc_relations : relationships +]</p><p style="max-width:100%;margin-bottom:0em;font-size:0.8em;">[+ pxc_leader +] <span style="font-style:italic;">([+ pxc_ideology +])</span></p></div></div> ?]
[? if fnc_parlament_s > 0 : <div style="margin-bottom:0.75em; display: flex; gap: 0.7em;"><div style="flex: 0 0 15%;align-content:center;"><img style="width:fit-content;" src="img/parties/logo_fnc.png"></div><div style="flex: 1 1 85%;"><p style="margin-top:-0.25em; margin-bottom:0em;"><span style="color: #55A0D9; font-weight: bold;">FNC</span> - [+ fnc_relations : relationships +]</p><p style="max-width:100%;margin-bottom:0em;font-size:0.8em;">[+ fnc_leader +] <span style="font-style:italic;">([+ fnc_ideology +])</span></p></div></div> ?]
[? if si_parlament_s > 0 : <div style="margin-bottom:0.75em; display: flex; gap: 0.7em;"><div style="flex: 0 0 15%;align-content:center;"><img style="width:fit-content; border: 1px solid black; border-radius: 5px;" src="img/parties/logo_si.jpg"></div><div style="flex: 1 1 85%;"><p style="margin-top:-0.25em; margin-bottom:0em;"><span style="color: #000000; font-weight: bold;">SI</span> - [+ si_relations : relationships +]</p><p style="max-width:100%;margin-bottom:0em;font-size:0.8em;">[+ si_leader +] <span style="font-style:italic;">([+ si_ideology +])</span></p></div></div> ?]


