!}

= INTERNATIONAL RELATIONS

<div style="display: flex; gap: 0.5em;font-size:0.9em;"><div style="flex: 0 0 20%;padding-left:0.2em;padding-top:0.2em;align-content:center;"><img style="width:fit-content;border-radius: 3px;" src="img/flags/eu.svg"></div><div style="flex: 0 0 80%;"><p style="font-weight: bold;margin-bottom:0em;">European Union</p>[+ international_eu_opinion : international_opinion +]</div></div>
<div style="display: flex; gap: 0.5em;margin-top:1em;font-size:0.9em;"><div style="flex: 0 0 20%;padding-left:0.2em;padding-top:0.2em;align-content:center;"><img style="width:fit-content;border-radius: 3px;" src="img/flags/russia.svg"></div><div style="flex: 0 0 80%;"><p style="font-weight: bold;margin-bottom:0em;">Russia</p>[+ international_russia_opinion : international_opinion +]</div></div>
<div style="display: flex; gap: 0.5em;margin-top:1em;font-size:0.9em;"><div style="flex: 0 0 20%;padding-left:0.2em;padding-top:0.2em;align-content:center;"><img style="width:fit-content;border-radius: 3px;" src="img/flags/usa.svg"></div><div style="flex: 0 0 80%;"><p style="font-weight: bold;margin-bottom:0em;">United States</p>[+ international_usa_opinion : international_opinion +]</div></div>
<div style="display: flex; gap: 0.5em;margin-top:1em;font-size:0.9em;"><div style="flex: 0 0 20%;padding-left:0.2em;padding-top:0.2em;align-content:center;"><img style="width:fit-content;border-radius: 3px;" src="img/flags/prc.svg"></div><div style="flex: 0 0 80%;"><p style="font-weight: bold;margin-bottom:0em;">P.R. China</p>[+ international_china_opinion : international_opinion +]</div></div>


