@international
title: International Relations

= INTERNATIONAL RELATIONS

<div style="display: flex; gap: 0.5em;font-size:0.9em;"><div style="flex: 0 0 20%;padding-left:0.2em;padding-top:0.2em;align-content:center;"><img style="width:fit-content;border-radius: 3px;" src="img/flags/eu.svg"></div><div style="flex: 0 0 80%;"><p style="font-weight: bold;margin-bottom:0em;">European Union</p>[+ international_eu_opinion : international_opinion +]</div></div>
<div style="display: flex; gap: 0.5em;margin-top:1em;font-size:0.9em;"><div style="flex: 0 0 20%;padding-left:0.2em;padding-top:0.2em;align-content:center;"><img style="width:fit-content;border-radius: 3px;" src="img/flags/russia.svg"></div><div style="flex: 0 0 80%;"><p style="font-weight: bold;margin-bottom:0em;">Russia</p>[+ international_russia_opinion : international_opinion +]</div></div>
<div style="display: flex; gap: 0.5em;margin-top:1em;font-size:0.9em;"><div style="flex: 0 0 20%;padding-left:0.2em;padding-top:0.2em;align-content:center;"><img style="width:fit-content;border-radius: 3px;" src="img/flags/usa.svg"></div><div style="flex: 0 0 80%;"><p style="font-weight: bold;margin-bottom:0em;">United States</p>[+ international_usa_opinion : international_opinion +]</div></div>
<div style="display: flex; gap: 0.5em;margin-top:1em;font-size:0.9em;"><div style="flex: 0 0 20%;padding-left:0.2em;padding-top:0.2em;align-content:center;"><img style="width:fit-content;border-radius: 3px;" src="img/flags/prc.svg"></div><div style="flex: 0 0 80%;"><p style="font-weight: bold;margin-bottom:0em;">P.R. China</p>[+ international_china_opinion : international_opinion +]</div></div>

= COUNTRY CONTROL

<div style="display: flex; gap: 1em;font-size:0.9em;flex-wrap:wrap;justify-content:center;"><div style="max-width:20%; display: flex; flex-direction: column; justify-content: center;"><div><img style="width:100%; height: 2em; border-radius: 3px;" src="img/plane_icon.svg"></div><div style="justify-content: center;display: flex;"> Airports </div> <div style="justify-content: center;display: flex;">[+ airports_control : control +]</div></div><div style="max-width:20%; display: flex;flex-direction: column; justify-content: center;"><div><img style="width:100%; height: 2em; border-radius: 3px;" src="img/train_icon.svg"></div><div style="justify-content: center;display: flex;"> Railways </div> <div style="justify-content: center;display: flex;">[+ railways_control : control +]</div></div><div style="max-width:20%; display: flex;flex-direction: column; justify-content: center;"><div><img style="width:100%; height: 2em; border-radius: 3px;" src="img/ship_icon.svg"></div><div style="justify-content: center;display: flex;"> Ports </div> <div style="justify-content: center;display: flex;">[+ ports_control : control +]</div></div><div style="max-width:20%; display: flex;flex-direction: column; justify-content: center;"><div><img style="width:100%; height: 2em; border-radius: 3px;" src="img/pass_icon.svg"></div><div style="justify-content: center;display: flex;"> Borders </div> <div style="justify-content: center;display: flex;">[+ borders_control : control +]</div></div><div style="max-width:30%; display: flex;flex-direction: column; justify-content: center;"><div><img style="width:100%; height: 2em; border-radius: 3px;" src="img/interior_icon.svg"></div><div style="justify-content: center;display: flex;"> Security </div> <div style="justify-content: center;display: flex;">[+ security_control : control +]</div></div><div style="max-width:30%; display: flex;flex-direction: column; justify-content: center;"><div><img style="width:100%; height: 2em; border-radius: 3px;" src="img/comms_icon.svg"></div><div style="justify-content: center;display: flex;"> Comms. </div> <div style="justify-content: center;display: flex;">[+ communications_control : control +]</div></div><div style="max-width:30%; display: flex;flex-direction: column; justify-content: center;"><div><img style="width:100%; height: 2em; border-radius: 3px;" src="img/economy_icon.svg"></div><div style="justify-content: center;display: flex;"> Taxation </div> <div style="justify-content: center;display: flex;">[+ tax_control : control +]</div></div></div>

@government
title: Government
on-arrival: {!
    Q.surplus_dataviz = Q.generalitat_surplus.toFixed(1)
    Q.gdp_growth_dataviz = Q.gdp_growth.toFixed(1)
    Q.unemployment_dataviz = Q.unemployment.toFixed(1)
!}

= [+ cat_coalition_disp +]

[? if cat_coalition_dissent != 0 : Coalition dissent: [+ cat_coalition_dissent : dissent +] ?]

<div style="display:flex; align-content:center;"><div style="width:20%; align-content:center"><img src="img/cat_seal.svg"></div><div style="width:80%; padding-left: 1em;"> **M.H.** [? if president_gender = "m": **President** ?][? if president_gender = "f": **Presidenta** ?]<br/>**[+ president +]** ([+ president_party +])<br/> <span style="font-size:0.8em;">**VP.** [+ vicepresident +] ([+ vicepresident_party +])</span></div></div></div>

<div style="display:flex; align-content:center;"><div style="width: 2em; align-content: center"><img style="height:1.5em;" src="img/economy_icon.svg"/></div><div> **Economy** ([+ economy_minister_party +])<br/><span style="font-size:0.8em">[+ economy_minister +]</span></div></div>

<div style="display:flex; align-content:center;"><div style="width: 2em; align-content: center"><img style="height:1.5em;" src="img/health_icon.svg"/></div><div> **Health** ([+ health_minister_party +])<br/><span style="font-size:0.8em">[+ health_minister +]</span></div></div>

<div style="display:flex; align-content:center;"><div style="width: 2em; align-content: center"><img style="height:1.5em;" src="img/education_icon.svg"/></div><div> **Education** ([+ education_minister_party +])<br/><span style="font-size:0.8em">[+ education_minister +]</span></div></div>

<div style="display:flex; align-content:center;"><div style="width: 2em; align-content: center"><img style="height:1.5em;" src="img/interior_icon.svg"/></div><div> **Interior** ([+ interior_minister_party +])<br/><span style="font-size:0.8em">[+ interior_minister +]</span></div></div>

<div style="display:flex; align-content:center;"><div style="width: 2em; align-content: center"><img style="height:1.5em;" src="img/international_icon.svg"/></div><div> **Foreign Affairs** ([+ foreign_minister_party +])<br/><span style="font-size:0.8em">[+ foreign_minister +]</span></div></div>

<div style="display:flex; align-content:center;width:105%"><div style="width: 2em; align-content: center"><img style="height:1.5em;" src="img/labour_icon.svg"/></div><div> **Business & Labour** ([+ bnl_minister_party +])<br/><span style="font-size:0.8em">[+ bnl_minister +]</span></div></div>

<div style="display:flex; align-content:center;"><div style="width: 2em; align-content: center"><img style="height:1.5em;" src="img/territory_icon.svg"/></div><div> **Territory** ([+ territory_minister_party +])<br/><span style="font-size:0.8em">[+ territory_minister +]</span></div></div>


