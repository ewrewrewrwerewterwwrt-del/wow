title: Status
new-page: true
is-special: true
on-arrival: {!
if (Q.spain_is_republic) {
    Q.spanish_seal_img = "img/esp_seal_republic.svg";
} else {
    Q.spanish_seal_img = "img/esp_seal.svg";
}
Q.unemployment_dataviz = Q.unemployment.toFixed(1);
!}

= Status

[? if rubicon: Week [+ week +] ,?][+ month : month +] [+ year +]

[? if player_party != 0 and position_disp != 0: [+ player_party +][? if player_in_jxsi: (JxSí)?][?if player_in_jxcat: (JxCat)?] position: [+ position_disp +] ?]

Party resources: [+ party_resources +]

[? if player_party == "erc": Internal dissent: [+ erc_dissent : dissent +] ?]
[? if player_party == "jxsi": Internal dissent: [+ jxsi_dissent : dissent +] ?]
[? if player_party == "ciu": Internal dissent: [+ ciu_dissent : dissent +] ?]
[? if player_party == "cup": Internal dissent: [+ cup_dissent : dissent +] ?]

[? if player_party == "erc": <div style="display: flex; align-items:center;gap:0.6em;"><div>Parlament: </div><div style="height:1.25em;margin-left:0.1em; border-radius:3px;min-width:60%; background-color: #dedede;"><div style="padding-left:0.2em;border-radius:3px;background-color: var(--erc);overflow:visible;height:1.25em;width:calc([+ erc_parlament_s +] / [+ parlament_size +] * 100%)"></div></div><p style="margin-bottom:0em;transform: translateX(-135%);font-size:0.8em;">[+ erc_parlament_s +]/[+ parlament_size +]</p></div> ?]
[? if player_party == "jxsi": <div style="display: flex; align-items:center;gap:0.6em;"><div>Parlament: </div><div style="height:1.25em;margin-left:0.1em; border-radius:3px;min-width:60%; background-color: #dedede;"><div style="padding-left:0.2em;border-radius:3px;background-color: var(--jxsi);overflow:visible;height:1.25em;width:calc([+ jxsi_parlament_s +] / [+ parlament_size +] * 100%)"></div></div><p style="margin-bottom:0em;transform: translateX(-135%);font-size:0.8em;">[+ jxsi_parlament_s +]/[+ parlament_size +]</p></div> ?]
[? if player_party == "ciu": <div style="display: flex; align-items:center;gap:0.6em;"><div>Parlament: </div><div style="height:1.25em;margin-left:0.1em; border-radius:3px;min-width:60%; background-color: #dedede;"><div style="padding-left:0.2em;border-radius:3px;background-color: var(--ciu);overflow:visible;height:1.25em;width:calc([+ ciu_parlament_s +] / [+ parlament_size +] * 100%)"></div></div><p style="margin-bottom:0em;transform: translateX(-135%);font-size:0.8em;">[+ ciu_parlament_s +]/[+ parlament_size +]</p></div> ?]
[? if player_party == "cup": <div style="display: flex; align-items:center;gap:0.6em;"><div>Parlament: </div><div style="height:1.25em;margin-left:0.1em; border-radius:3px;min-width:60%; background-color: #dedede;"><div style="padding-left:0.2em;border-radius:3px;background-color: var(--cup);overflow:visible;height:1.25em;width:calc([+ cup_parlament_s +] / [+ parlament_size +] * 100%)"></div></div><p style="margin-bottom:0em;transform: translateX(-135%);font-size:0.8em;">[+ cup_parlament_s +]/[+ parlament_size +]</p></div> ?]

= Government

<div style="display: flex; gap: 0.62em;margin-bottom: -0.75em;"><div style="flex: 0 0 15%;padding-left:0.2em"><img src="img/cat_seal.svg"></div><div style="flex: 1 1 84%;"><p style="font-weight:bold; margin-top:-0.25em; margin-bottom:0.25em;">Generalitat</p><p style="white-space:nowrap; overflow:visible; text-overflow:ellipsis;max-width:95%;">[+ cat_coalition_disp +]</p></div></div>

[? if president_gender = "m": President ?][? if president_gender = "f": Presidenta ?][+ president +] ([+ president_party +])

Next election: [+ next_election_month : month +] [+ next_election_year +]


<div style="display: flex; gap: 0.5em;margin-top:1.1em;margin-bottom: -0.75em;"><div style="flex: 0 0 18%;"><img src="[+spanish_seal_img+]"></div><div style="flex: 1 1 82%;"><p style="font-weight:bold; margin-top:-0.1em; margin-bottom:0.25em;">Gobierno</p><p style="white-space:nowrap; overflow:visible; text-overflow:ellipsis;max-width:95%;">[+ spanish_coalition_disp +]</p></div></div>

[? if spanish_pm_gender = "m": Presidente ?][? if spanish_pm_gender = "f": Presidenta ?][+ spanish_pm +] ([+ spanish_pm_party +])

Next election: [+ next_spanish_election_month : month +] [+ next_spanish_election_year +]

Tensions: [+ cat_spa_relations : cat_spa_relations +]

= Economy and Society

Debt status: [+ public_debt : public_debt_qualifier +]

Unemployment: [+ unemployment_dataviz +]% [+ unemployment_change +]

Independence movement momentum: [+ independence_movement : independence_movement +]

Social dissent: [+ social_dissent : social_dissent +] 


@politics
title: Politics
on-arrival: {!
var parlament_size = 0;
for (var constituency of Q.parlament_constituencies) {
    parlament_size += Q.parlament_seats[constituency];
}
Q.parlament_s_majority = Math.floor(parlament_size/2) + 1;

Q.parlament_max_seats = 0;
for (var party of Q.parties) {
    var party_seats = Q[party + "_parlament_s"];
    if (party_seats > Q.parlament_max_seats) {
        Q.parlament_max_seats = party_seats;
    }
}
!}

= [+ player_party +] Factions

**Roadmap:** [? if player_party = "erc": [+ erc_roadmap : roadmap +]?][? if player_party = "jxsi": [+ jxsi_roadmap : roadmap +]?][? if player_party = "ciu": [+ ciu_roadmap : roadmap +]?][? if player_party = "cup": [+ cup_roadmap : roadmap +]?][? if player_party=None: [+ player_party : roadmap +] ?] [? if roadmap_year: ([+ roadmap_year +]) ?]

[? if player_party = "erc": <div style="display:flex;"><div style="display:flex; align-items:center; justify-content:left; font-weight: bold; width: 40%;"> Left </div><div style="display:flex; font-size: 0.8em; margin-left: 1em; flex-direction:column;"> <div> Strength: [+ erc_left_strength : dissent +] </div><div> Dissent: [+ erc_left_dissent : dissent +]</div> </div> </div>?]

[? if player_party = "erc":<div style="display:flex;"><div style="display:flex; align-items:center; justify-content:left; font-weight: bold; width: 40%;"> Republican Core </div><div style="display:flex; font-size: 0.8em; margin-left: 1em; flex-direction:column;"> <div> Strength: [+ erc_core_strength : dissent +] </div><div> Dissent: [+ erc_core_dissent : dissent +]</div> </div> </div>?]

[? if player_party = "erc": <div style="display:flex;"><div style="display:flex; align-items:center; justify-content:left; font-weight: bold; width: 40%;"> Pragmatics </div><div style="display:flex; font-size: 0.8em; margin-left: 1em; flex-direction:column;"> <div> Strength: [+ erc_pragmatic_strength : dissent +] </div><div> Dissent: [+ erc_pragmatic_dissent : dissent +]</div> </div> </div>?]

[? if player_party = "erc": <div style="display:flex;"><div style="display:flex; align-items:center; justify-content:left; font-weight: bold; width: 40%;"> Civil Orgs. </div><div style="display:flex; font-size: 0.8em; margin-left: 1em; flex-direction:column;"> <div> Strength: [+ erc_civic_strength : dissent +] </div><div> Dissent: [+ erc_civic_dissent : dissent +]</div> </div> </div>?]

[? if player_party = "cup": <div style="display:flex;"><div style="display:flex; align-items:center; justify-content:left; font-weight: bold; width: 40%;"> Endavant </div><div style="display:flex; font-size: 0.8em; margin-left: 1em; flex-direction:column;"> <div> Strength: [+ cup_endavant_strength : dissent +] </div><div> Dissent: [+ cup_endavant_dissent : dissent +]</div> </div> </div>?]

[? if player_party = "cup": <div style="display:flex;"><div style="display:flex; align-items:center; justify-content:left; font-weight: bold; width: 40%;"> Poble Lliure </div><div style="display:flex; font-size: 0.8em; margin-left: 1em; flex-direction:column;"> <div> Strength: [+ cup_poblelliure_strength : dissent +] </div><div> Dissent: [+ cup_poblelliure_dissent : dissent +]</div> </div> </div>?]

[? if player_party = "cup": <div style="display:flex;"><div style="display:flex; align-items:center; justify-content:left; font-weight: bold; width: 40%;"> Third Sector </div><div style="display:flex; font-size: 0.8em; margin-left: 1em; flex-direction:column;"> <div> Strength: [+ cup_thirdsector_strength : dissent +] </div><div> Dissent: [+ cup_thirdsector_dissent : dissent +]</div> </div> </div>?]


= PARLAMENT

<div style="margin-top:1.5em;overflow:visible;">
[? if jxsi_parlament_s > 0: <div style="margin-bottom:0.75em; font-size:0.9em; margin-top:-1em; display: flex; align-items:center;gap:0em;width:100%;"> <div style='width:3em;overflow:visible;'> jxsi </div><div style='height:1.1em; background-color: var(--jxsi); width:calc([+ jxsi_parlament_s +] * 65% / [+ parlament_max_seats +]);margin-right:0.5em;border-radius: 0px 3px 3px 0px;'></div>[+jxsi_parlament_s+]</div>?]
