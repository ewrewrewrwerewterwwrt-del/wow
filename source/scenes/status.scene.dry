<div style="font-size:0.8em;line-height:140%;margin-top:-1em; text-align:center;">Speaker of the House <br/>[+ speaker +] ([+ speaker_party +])</div>

[? if (erc_parlament_s > 0) and (player_party != "erc"): <div style="margin-bottom:0.75em; display: flex; gap: 0.7em;"><div style="flex: 0 0 15%;align-content:center;"><img style="width:fit-content;" src="img/parties/logo_erc.svg"></div><div style="flex: 1 1 85%;"><p style="margin-top:-0.25em; margin-bottom:0em;"> ERC - [+ erc_relations : relationships +]</p><p style="max-width:100%;margin-bottom:0em;font-size:0.8em;">[+ erc_leader +] <span style="font-style:italic;">([+ erc_ideology +])</span></p></div></div> ?]
[? if (not player_in_jxsi) and (jxsi_parlament_s > 0): <div style="margin-bottom:0.75em; display: flex; gap: 0.7em;"><div style="flex: 0 0 15%;align-content:center;"><img style="width:fit-content; border-radius: 5px;" src="img/parties/logo_jxsi.png"></div><div style="flex: 1 1 85%;"><p style="margin-top:-0.25em; margin-bottom:0em;"> jxsi  - [+ jxsi_relations : relationships +]</p><p style="max-width:100%;margin-bottom:0em;font-size:0.8em;">[+ jxsi_leader +] <span style="font-style:italic;">([+ jxsi_ideology +])</span></p></div></div> ?]
[? if (ciu_parlament_s > 0) and (player_party != "ciu"): <div style="margin-bottom:0.75em; display: flex; gap: 0.7em;"><div style="flex: 0 0 15%;align-content:center;"><img style="width:fit-content;" src="img/parties/logo_ciu.png"></div><div style="flex: 1 1 85%;"><p style="margin-top:-0.25em; margin-bottom:0em;"> CiU - [+ ciu_relations : relationships +]</p><p style="max-width:100%;margin-bottom:0em;font-size:0.8em;">[+ ciu_leader +] <span style="font-style:italic;">([+ ciu_ideology +])</span></p></div></div> ?]
[? if (not player_in_jxcat) and (jxcat_parlament_s > 0): <div style="margin-bottom:0.75em; display: flex; gap: 0.7em;"><div style="flex: 0 0 15%;align-content:center;"><img style="width:fit-content;" src="img/parties/logo_jxcat.svg"></div><div style="flex: 1 1 85%;"><p style="margin-top:-0.25em; margin-bottom:0em;"> JxCat - [+ jxcat_relations : relationships +]</p><p style="max-width:100%;margin-bottom:0em;font-size:0.8em;">[+ jxcat_leader +] <span style="font-style:italic;">([+ jxcat_ideology +])</span></p></div></div> ?]
[? if (player_party != "junts") and (junts_parlament_s > 0): <div style="margin-bottom:0.75em; display: flex; gap: 0.7em;"><div style="flex: 0 0 15%;align-content:center;"><img style="width:fit-content;" src="img/parties/logo_junts.svg"></div><div style="flex: 1 1 85%;"><p style="margin-top:-0.25em; margin-bottom:0em;"> Junts - [+ junts_relations : relationships +]</p><p style="max-width:100%;margin-bottom:0em;font-size:0.8em;">[+ junts_leader +] <span style="font-style:italic;">([+ junts_ideology +])</span></p></div></div>  ?]
[? if (player_party != "dl") and (dl_parlament_s > 0): <div style="margin-bottom:0.75em; display: flex; gap: 0.7em;"><div style="flex: 0 0 15%;align-content:center;"><img style="width:fit-content;" src="img/parties/logo_dl.png"></div><div style="flex: 1 1 85%;"><p style="margin-top:-0.25em; margin-bottom:0em;"> DL - [+ dl_relations : relationships +]</p><p style="max-width:100%;margin-bottom:0em;font-size:0.8em;">[+ dl_leader +] <span style="font-style:italic;">([+ dl_ideology +])</span></p></div></div>  ?]
[? if (player_party != "cdc") and (cdc_parlament_s > 0): <div style="margin-bottom:0.75em; display: flex; gap: 0.7em;"><div style="flex: 0 0 15%;align-content:center;"><img style="width:fit-content;" src="img/parties/logo_cdc.png"></div><div style="flex: 1 1 85%;"><p style="margin-top:-0.25em; margin-bottom:0em;"> CDC - [+ cdc_relations : relationships +]</p><p style="max-width:100%;margin-bottom:0em;font-size:0.8em;">[+ cdc_leader +] <span style="font-style:italic;">([+ cdc_ideology +])</span></p></div></div> ?]
[? if (player_party != "pdcat") and (pdcat_parlament_s > 0): <div style="margin-bottom:0.75em; display: flex; gap: 0.7em;"><div style="flex: 0 0 15%;align-content:center;"><img style="width:fit-content;" src="img/parties/logo_pdecat.svg"></div><div style="flex: 1 1 85%;"><p style="margin-top:-0.25em; margin-bottom:0em;"> PDeCAT - [+ pdcat_relations : relationships +]</p><p style="max-width:100%;margin-bottom:0em;font-size:0.8em;">[+ pdcat_leader +] <span style="font-style:italic;">([+ pdcat_ideology +])</span></p></div></div> ?]
[? if cs_parlament_s > 0 : <div style="margin-bottom:0.75em; display: flex; gap: 0.7em;"><div style="flex: 0 0 15%;align-content:center;"><img style="width:fit-content;" src="img/parties/logo_cs.svg"></div><div style="flex: 1 1 85%;"><p style="margin-top:-0.25em; margin-bottom:0em;"> Cs - [+ cs_relations : relationships +]</p><p style="max-width:100%;margin-bottom:0em;font-size:0.8em;">[+ cs_leader +] <span style="font-style:italic;">([+ cs_ideology +])</span></p></div></div> ?]
[? if psc_parlament_s > 0 : <div style="margin-bottom:0.75em; display: flex; gap: 0.7em;"><div style="flex: 0 0 15%;align-content:center;"><img src="img/parties/logo_psc.svg"></div><div style="flex: 1 1 85%;"><p style="margin-top:-0.25em; margin-bottom:0em;"> PSC - [+ psc_relations : relationships +]</p><p style="max-width:100%;margin-bottom:0em;font-size:0.8em;">[+ psc_leader +] <span style="font-style:italic;">([+ psc_ideology +])</span></p></div></div> ?]
