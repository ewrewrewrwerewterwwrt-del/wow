[? if parlament_s_majority > 0 : <p style="text-align:right;font-style:italic;font-size:0.8em;margin-top:-2em;margin-right:0.5em;">Majority: [+ parlament_s_majority +]</p> ?]
</div>

[? if (erc_parlament_s > 0) and (player_party != "erc"): <div style="margin-bottom:0.75em; display: flex; gap: 0.7em;"><div style="flex: 0 0 15%;align-content:center;"><img style="width:fit-content;" src="img/parties/logo_erc.svg"></div><div style="flex: 1 1 85%;"><p style="margin-top:-0.25em; margin-bottom:0em;"><span style="color: #ff8000; font-weight: bold;">ERC</span> - [+ erc_relations : relationships +]</p><p style="max-width:100%;margin-bottom:0em;font-size:0.8em;">[+ erc_leader +] <span style="font-style:italic;">([+ erc_ideology +])</span></p></div></div> ?]
[? if (player_party != "jxsi") and (jxsi_parlament_s > 0): <div style="margin-bottom:0.75em; display: flex; gap: 0.7em;"><div style="flex: 0 0 15%;align-content:center;"><img style="width:fit-content; border-radius: 5px;" src="img/parties/logo_jxsi.png"></div><div style="flex: 1 1 85%;"><p style="margin-top:-0.25em; margin-bottom:0em;"><span style="color: #20c0b2; font-weight: bold;">JxSí</span> - [+ jxsi_relations : relationships +]</p><p style="max-width:100%;margin-bottom:0em;font-size:0.8em;">[+ jxsi_leader +] <span style="font-style:italic;">([+ jxsi_ideology +])</span></p></div></div> ?]
