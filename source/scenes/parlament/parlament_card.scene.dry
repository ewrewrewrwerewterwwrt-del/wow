title: Parlament
new-page: true
view-if: parlament_timer <= 0 and year > 2012
on-arrival: parlament_timer += 6; month_actions += 1; coming_from_parlament = false;
is-card: true
card-image: img/parlament_card.jpg
tags: erc_party cup_party parlament_card
go-to: parlament_options


