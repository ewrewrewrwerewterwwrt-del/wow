@post_election_sim
on-arrival: {!
var parlament_size = 0;
for (var constituency of Q.parlament_constituencies) {
    parlament_size += Q.parlament_seats[constituency];
}
Q.parlament_s_majority = Math.floor(parlament_size/2) + 1;

console.log("Total seats: " + parlament_size + ", majority: " + Q.parlament_s_majority);
!}
on-display: {!
const data = [];

if (Q.si_parlament_s) {
    data.push({
        "id": "si",
        "legend": "SI",
        "name": "SI",
        "seats": Q.si_parlament_s,
    });
}

