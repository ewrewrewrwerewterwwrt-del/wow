[? if pxc_parlament_showviz: {!<tr><td><div class="box" style='background-color: #00FFFF'> </div> !} PxC {!</td><td style='text-align: right;'>!}[+ pxc_parlament_pv +]% {!</td><td>!} [+ pxc_parlament_pv_delta +] {!</td><td style='text-align: right;'>!} [+ pxc_parlament_s +] {!</td><td>!} [+ pxc_parlament_s_delta +] {!</td>!}?]
[? if fnc_parlament_showviz: {!<tr><td><div class="box" style='background-color: #55A0D9'> </div> !} FNC {!</td><td style='text-align: right;'>!}[+ fnc_parlament_pv +]% {!</td><td>!} [+ fnc_parlament_pv_delta +] {!</td><td style='text-align: right;'>!} [+ fnc_parlament_s +] {!</td><td>!} [+ fnc_parlament_s_delta +] {!</td>!}?]
[? if si_parlament_showviz: {!<tr><td><div class="box" style='background-color: #000000'> </div> !} SI {!</td><td style='text-align: right;'>!}[+ si_parlament_pv +]% {!</td><td>!} [+ si_parlament_pv_delta +] {!</td><td style='text-align: right;'>!} [+ si_parlament_s +] {!</td><td>!} [+ si_parlament_s_delta +] {!</td>!}?]
{!</table>!}

{!<div style="width: 95%;text-align: center; margin-top:-0.75em;">!} **Turnout:**  [+ parlament_participation_pc +]% ([+ parlament_participation_delta +]) {!</div>!}
{!<div style="width: 95%; justify-content: center; margin-top:-1em; display:flex;"><div class="box" style="width: 70%; border-radius: 3px; background-color: #ccc"><div class="box" style="display: inline-block; height: 1em; background-color: dimgrey; margin-right: 0.5em; border-radius: 3px; width:!}[+ parlament_participation_pc+]{!%;"></div></div></div>!}

{!<table style='border-spacing: 0px; margin-right: 1em; margin-left: 1em; width:95%; table-layout: fixed;'>!}
{!<tr><td style='width: !}[+ independence_parlament_pv +]{!%'>Independence</td><td style='text-align: center; width: !}[+ nonaligned_parlament_pv +]{!%'>Unaligned</td><td style='text-align: right; width: !}[+ unionist_parlament_pv +]{!%'>Union</td></tr>!}
{!<tr><td style='height: 2em; background-color: #008000; color: white; text-align: center; border-radius: 3px 0 0 3px;'>!}**[+ independence_parlament_pv +]%**{!</td><td style='background-color: #b1b0aeff; color: black; text-align: center'>!}**[+ nonaligned_parlament_pv +]%**{!</td><td style='background-color: #fe0101; color: white; text-align: center; border-radius: 0 3px 3px 0;'>!}**[+ unionist_parlament_pv +]%**{!</td></tr>!}
{!</table>!}
{!<div style="font-style: italic; margin-top: -1em; margin-left: 3em">Popular vote</div>!}

{!<table style='border-spacing: 0px; margin-right: 1em; margin-left: 1em; width:95%; table-layout: fixed; margin-top:-0.75em;'>!}
{!<tr><td style='overflow:hidden; white-space: nowrap; width: !}[+ independence_parlament_spc +]{!%; height: 2em; background-color: #008000; color: white; text-align: center; border-radius: 3px 0 0 3px;'>!}**[+ independence_parlament_s+]** ([+ independence_parlament_spc +]%) {!</td><td style='overflow:hidden; white-space: nowrap; width: !}[+ nonaligned_parlament_spc +]{!%; background-color: #b1b0aeff; color: black; text-align: center'>!}**[+ nonaligned_parlament_s+]** ([+ nonaligned_parlament_spc +]%) {!</td><td style='overflow:hidden; white-space: nowrap; width: !}[+ unionist_parlament_spc +]{!%; background-color: #fe0101; color: white; text-align: center; border-radius: 0 3px 3px 0;'>!}**[+ unionist_parlament_s+]** ([+ unionist_parlament_spc +]%) {!</td></tr>!}
{!</table>!}
{!<div style="font-style: italic; margin-top: -1em; margin-left: 3em">Parlament control</div>!}

[? if ciu_parlament_s > 0 : Note: <span style='color: #002782; font-weight: bold;width:95%;'>CiU</span> has been unclear about their position on independence, so it is counted as unaligned. ?]
[? if jxsi_parlament_s > 0 : Author's note: I am aware that in this simulation the pro-independence parties get a majority of the votes instead of a plurality. I do not know if I'll fix it, because I only used the weights as a rough guide, not as something set in stone. ?]

**Government Formation**
# yeah this is hardcoded because its only the simulation scenes

[? if ciu_parlament_showviz: <span style='color: #002782; font-weight: bold;'>CiU</span> will be able to form a <span style='color: #002782; font-style: italic;'>minority government</span> with <span style='color: #ff8000; font-weight: bold;'>ERC</span>'s assent. ?]

[? if jxsi_parlament_showviz: <span style='color: #3ab6a5; font-weight: bold;'>JxSí</span> will need <span style='color: #C4B156; font-weight: bold;'>CUP</span>'s assent to form a <span style='color: #3ab6a5; font-style: italic;'>Sovereignty government</span>. ?]

[? if junts_parlament_showviz: <span style='color: #3ab6a5; font-weight: bold;'>Junts</span> and <span style='color: #ff8000; font-weight: bold;'>ERC</span> will form a <span style='color: #bfa62d; font-style: italic;'>sovereignty government</span> with <span style='color: #C4B156; font-weight: bold;'>CUP</span>'s assent. ?]

[? if not (ciu_parlament_showviz or jxsi_parlament_showviz or junts_parlament_showviz): How did we get here??? ?]

- @election_simulation: Reset simulation

@post_election_sim_congreso
on-arrival: {!
var congreso_size = 0;
for (var constituency of Q.congreso_constituencies) {
    congreso_size += Q.congreso_seats[constituency];
}
Q.congreso_s_majority = Math.floor(congreso_size/2) + 1;

console.log("Total seats: " + congreso_size + ", majority: " + Q.congreso_s_majority);
!}
