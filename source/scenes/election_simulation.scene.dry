{!<div style="width: 95%; justify-content: center; display:flex;"><div class="box" style="width: 70%; border-radius: 3px; background-color: #ccc"><div class="box" style="height: 1em; background-color: dimgrey; margin-right: 0.5em; border-radius: 3px; width:!}[+ congreso_participation_pc+]{!%;"></div></div></div>!}

Author's note: Congreso election simulations are more imperfect than Parlament ones, but the main goal of the in-game dynamic is to capture the general trends and the possible government formations, pacts, and deadlocks, which is mostly achieved.

**Government Formation**

[? if dl_congreso_showviz: No candidacy has been able to secure enough support to form a new government. New elections will happen in **June 2016**. ?]
[? if pdcat_congreso_showviz: Mariano Rajoy will lead a PP <span style='color: #1d84ce;'>minority government</span> with the support of Cs, CC-PNC, and the toleration of a broken PSOE.?]
[? if jxcat_congreso_showviz and fr_congreso_showviz: No candidacy has been able to secure enough support to form a new government. New elections will happen in **November 2019**. ?]
[? if jxcat_congreso_showviz and not fr_congreso_showviz: Pedro Sánchez will lead a <span style='color: #da291c; font-weight: bold;'>progressist</span> <span style='color: #5a205a; font-weight: bold;'>government</span> (PSOE-UP) with the support of EAJ-PNV, Más País, BNG, CC-PNC, texiste and the toleration of ERC and EH Bildu. ?]

[? if not (dl_congreso_showviz or pdcat_congreso_showviz or jxcat_congreso_showviz): How did we get here??? ?]

- @election_simulation: Reset simulation


@post_election_sim_local
set-bg: img/salo_de_cent.jpg
on-arrival: {!
    Q.local_barcelona_seats = 41;
    Q.barcelona_s_majority = Math.floor(Q.local_barcelona_seats/2) + 1;
!}
on-display: {!
    const data = [];
    if (Q.cup_local_barcelona_s) {
        data.push({
            "id": "cup",
            "legend": "CUP",
            "name": "CUP",
            "seats": Q.cup_local_barcelona_s,
        });
    }
    if (Q.primaries_local_barcelona_s) {
        data.push({
            "id": "primaries",
            "legend": "Primàries",
            "name": "Primàries",
            "seats": Q.primaries_local_barcelona_s,
        });
    }
    if (Q.bcomu_local_barcelona_s) {
        data.push({
            "id": "bcomu",
            "legend": "BComú",
            "name": "BComú",
            "seats": Q.bcomu_local_barcelona_s,
        });
    }
    if (Q.icv_local_barcelona_s) {
        data.push({
            "id": "icv",
            "legend": "ICV-EUiA",
            "name": "ICV-EUiA",
            "seats": Q.icv_local_barcelona_s,
        });
    }
    if (Q.erc_local_barcelona_s) {
        data.push({
            "id": "erc",
            "legend": "ERC",
            "name": "ERC",
            "seats": Q.erc_local_barcelona_s,
        });
    }
    if (Q.psc_local_barcelona_s) {
        data.push({
            "id": "psc",
            "legend": "PSC",
            "name": "PSC",
            "seats": Q.psc_local_barcelona_s,
        });
    }
    if (Q.cs_local_barcelona_s) {
        data.push({
            "id": "cs",
            "legend": "Cs",
            "name": "Cs",
            "seats": Q.cs_local_barcelona_s,
        });
    }
    if (Q.jxsi_local_barcelona_s) {
        data.push({
            "id": "jxsi",
            "legend": "JxSí",
            "name": "JxSí",
            "seats": Q.jxsi_local_barcelona_s,
        });
    }
    if (Q.jxcat_local_barcelona_s) {
        data.push({
            "id": "jxcat",
            "legend": "JxCat",
            "name": "JxCat",
            "seats": Q.jxcat_local_barcelona_s,
        });
    }
    if (Q.junts_local_barcelona_s) {
        data.push({
            "id": "junts",
            "legend": "Junts",
            "name": "Junts",
            "seats": Q.junts_local_barcelona_s,
        });
    }
    if (Q.cdc_local_barcelona_s) {
        data.push({
            "id": "cdc",
            "legend": "CDC",
            "name": "CDC",
            "seats": Q.cdc_local_barcelona_s,
        });
    }
    if (Q.ciu_local_barcelona_s) {
        data.push({
            "id": "ciu",
            "legend": "CiU",
            "name": "CiU",
            "seats": Q.ciu_local_barcelona_s,
        });
    }
    if (Q.pdcat_local_barcelona_s) {
        data.push({
            "id": "pdcat",
            "legend": "PDeCAT",
            "name": "PDeCAT",
            "seats": Q.pdcat_local_barcelona_s,
        });
    }
    if (Q.unio_local_barcelona_s) {
        data.push({
            "id": "unio",
            "legend": "UDC",
            "name": "UDC",
            "seats": Q.unio_local_barcelona_s,
        });
    }
    if (Q.dl_local_barcelona_s) {
        data.push({
            "id": "dl",
            "legend": "DL",
            "name": "DL",
            "seats": Q.dl_local_barcelona_s,
        });
    }
    if (Q.pp_local_barcelona_s) {
        data.push({
            "id": "pp",
            "legend": "PP",
            "name": "PP",
            "seats": Q.pp_local_barcelona_s,
        });
    }
    if (Q.fnc_local_barcelona_s) {
        data.push({
            "id": "fnc",
            "legend": "FNC",
            "name": "FNC",
            "seats": Q.fnc_local_barcelona_s,
        });
    }
    if (Q.pxc_local_barcelona_s) {
        data.push({
            "id": "pxc",
            "legend": "PxC",
            "name": "PxC",
            "seats": Q.pxc_local_barcelona_s,
        });
    }
    if (Q.vox_local_barcelona_s) {
        data.push({
            "id": "vox",
            "legend": "Vox",
            "name": "Vox",
            "seats": Q.vox_local_barcelona_s,
        });
    }

    console.log(data);

    if (window && d3) {
        var width = 500;
        var height = 500;
        var screenWidth =  document.getElementById('content').offsetWidth;
        if (screenWidth < width - 50) {
            width = screenWidth - 50;
            height = width;
            document.getElementById("barcelonalocal").style.height = screenWidth/2 + "px";
        }
        var parliament = d3.parliament();
        parliament.width(width).height(height).innerRadiusCoef(0.4);
        parliament.enter.fromCenter(true).smallToBig(true);
        parliament.exit.toCenter(false).bigToSmall(true);
        d3.select("#barcelonalocal").datum(data).call(parliament);
    }
!}

= Barcelona Local Election Results

{!<svg id="barcelonalocal" style="width: 500px; height: 250px;"> </svg>!}
