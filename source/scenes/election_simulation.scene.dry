- @election_simulation: Reset simulation

@post_election_sim_congreso
on-arrival: {!
var congreso_size = 0;
for (var constituency of Q.congreso_constituencies) {
    congreso_size += Q.congreso_seats[constituency];
}
Q.congreso_s_majority = Math.floor(congreso_size/2) + 1;

console.log("Total seats: " + congreso_size + ", majority: " + Q.congreso_s_majority);
!}
