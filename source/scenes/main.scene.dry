@party_erc
title: Party Affairs
card-image: img/erc/executiva.jpg
is-deck: true
view-if: player_party = "erc"

- #erc_party

@party_cup
title: Party Affairs
card-image: img/cup/seunacional.jpg
is-deck: true
view-if: player_party = "cup"

- #cup_party

@cat_gov
title: Generalitat
view-if: (player_party = "erc" and erc_in_gov)
card-image: img/generalitat.jpg
is-deck: true
